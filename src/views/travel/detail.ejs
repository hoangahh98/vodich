<%- include('../partials/head', { title: trip.name }) %>
<%- include('../partials/topbar') %>
<%
  const sections = [
    { key: 'overview', label: '📊 Tổng quan' },
    { key: 'members', label: '👥 Thành viên' },
    { key: 'expenses', label: '🧾 Khoản chi' },
    { key: 'ai', label: '🤖 AI gợi ý' },
  ];
  if (hasPlaces) sections.push({ key: 'places', label: '🧭 Gợi ý' });
  if (isTravelAdmin) sections.push({ key: 'settings', label: '⚙️ Cài đặt' });
%>
<main class="app-shell travel-shell" data-travel-trip-id="<%= trip.id %>">
  <section class="feature-hero p mb">
    <div class="flex between center gap">
      <div>
        <h1>🌴 <%= trip.name %></h1>
        <div class="muted strong-muted">📍 <%= trip.destination?.name || 'Chưa chọn địa danh' %> · 👥 <%= members.length %> thành viên · 💸 <%= formatMoney(summary.totalSpent) %>đ</div>
      </div>
      <div class="feature-hero-art">🌴</div>
    </div>
  </section>

  <!-- ===== TỔNG QUAN ===== -->
  <% if (section === 'overview') { %>
    <div class="grid finance-grid mb">
      <div class="metric-card blue"><span>Tổng thu</span><strong><%= formatMoney(summary.totalCollectedDisplay) %>đ</strong><small><%= members.length %> người</small></div>
      <div class="metric-card green"><span>Tổng ứng trước</span><strong><%= formatMoney(summary.totalAdvanced) %>đ</strong><small>Thành viên đã trả hộ</small></div>
      <div class="metric-card red"><span>Tổng chi</span><strong><%= formatMoney(summary.totalSpent) %>đ</strong><small><%= expenses.length %> khoản chi</small></div>
      <div class="metric-card <%= summary.balance >= 0 ? 'gold' : 'red' %>"><span>Còn lại</span><strong><%= formatMoney(summary.balance) %>đ</strong><small><%= summary.balance >= 0 ? 'Dư/đủ quỹ' : 'Còn thiếu' %></small></div>
    </div>

    <% if (summary.paymentSuggestions.length) { %>
      <section class="card-lite p mb">
        <div class="section-heading mb"><div><span class="feature-icon">🔁</span><h2 class="section-title">Gợi ý chuyển tiền</h2></div></div>
        <div class="grid travel-suggestion-payments">
          <% summary.paymentSuggestions.forEach((item) => { %><div class="alert-lite"><strong><%= item.fromName %></strong> chuyển <strong><%= formatMoney(item.amount) %>đ</strong> cho <strong><%= item.toName %></strong></div><% }) %>
        </div>
      </section>
    <% } else { %>
      <section class="card-lite p mb"><p class="muted text-center">Thu chi đang cân bằng, chưa cần chuyển tiền.</p></section>
    <% } %>

    <% if (isTravelAdmin) { %>
      <section class="card-lite p mb">
        <div class="section-heading mb"><div><span class="feature-icon">💰</span><h2 class="section-title">Thu tiền</h2></div></div>
        <form method="post" action="/travel/trips/<%= trip.id %>/treasurer" class="travel-treasurer-form mb">
          <div><label>Thủ quỹ</label><select name="treasurerMemberId"><option value="">Chưa chọn</option><% members.forEach((member) => { %><option value="<%= member.id %>" <%= String(trip.treasurerMemberId || '') === String(member.id) ? 'selected' : '' %>><%= member.name %></option><% }) %></select></div>
          <button class="btn btn-primary" data-loading-text="Đang lưu...">Lưu thủ quỹ</button>
        </form>
        <% if (members.length) { %>
        <form method="post" action="/travel/trips/<%= trip.id %>/collections">
          <div class="travel-frozen-wrap">
            <table class="travel-table travel-table-sticky">
              <thead><tr><th class="sticky-col">Thành viên</th><th>Đã thu</th><th>Đã trả</th><th>Ứng trước</th><th>Còn thiếu</th><th>Ghi chú</th></tr></thead>
              <tbody>
                <% members.forEach((member) => { const key = member.id.toString(); const isTreasurer = String(trip.treasurerMemberId || '') === key; %>
                  <tr class="<%= (summary.balances.get(key) || 0) >= 0 ? 'sufficient-row' : 'insufficient-row' %>">
                    <td class="sticky-col"><strong><%= member.name %></strong><% if (isTreasurer) { %><br><span class="badge">Thủ quỹ</span><% } %></td>
                    <td>
                      <% const memberSpent = summary.memberSpent.get(key) || 0; const memberPaid = summary.memberPaidTotal.get(key) || 0; const actualCollected = summary.actualCollected ? summary.actualCollected.get(key) || 0 : Number(member.collections[0]?.amount || 0); %>
                      <% if (isTreasurer) { %>
                        <input type="hidden" name="collection_<%= key %>" value="<%= formatMoney(memberSpent) %>">
                        <input class="money-input" value="<%= formatMoney(memberSpent) %>" readonly>
                        <small class="muted">Theo phần thủ quỹ.</small>
                      <% } else if (memberPaid >= memberSpent && memberSpent > 0) { %>
                        <input type="hidden" name="collection_<%= key %>" value="<%= formatMoney(actualCollected) %>">
                        <input class="money-input" value="<%= formatMoney(actualCollected) %>" readonly>
                        <small class="text-success">Đã đủ.</small>
                      <% } else { %>
                        <input class="money-input" name="collection_<%= key %>" value="<%= formatMoney(actualCollected) %>">
                      <% } %>
                    </td>
                    <td><strong><%= formatMoney(memberPaid) %>đ</strong></td>
                    <td><strong class="text-success"><%= formatMoney(summary.memberAdvanced.get(key) || 0) %>đ</strong></td>
                    <td><strong class="<%= (summary.memberDebt.get(key) || 0) > 0 ? 'text-danger' : 'text-success' %>"><%= formatMoney(summary.memberDebt.get(key) || 0) %>đ</strong></td>
                    <td><input name="collectionNote_<%= key %>" value="<%= member.collections[0]?.note || '' %>"></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="form-actions"><button class="btn btn-success" data-loading-text="Đang lưu...">Lưu tiền thu</button><button class="btn btn-primary" formaction="/travel/trips/<%= trip.id %>/collections/paid-enough" data-confirm="Cập nhật thu đủ theo phần chi hiện tại?">Thu đủ</button></div>
        </form>
        <% } %>
      </section>
    <% } %>
  <% } %>

  <!-- ===== THÀNH VIÊN & THU TIỀN ===== -->
  <% if (section === 'members') { %>
    <% if (isTravelAdmin) { %>
      <section class="card-lite p mb">
        <div class="section-heading mb"><div><span class="feature-icon">➕</span><h2 class="section-title">Thêm thành viên</h2></div></div>
        <% if (availablePlayers.length) { %>
          <form class="mb" method="post" action="/travel/trips/<%= trip.id %>/members" data-require-checked="playerId">
            <label class="muted">Chọn từ danh sách chung (tích nhiều người một lúc)</label>
            <div class="player-check-list mb" data-player-picker>
              <% availablePlayers.forEach((player) => { %>
                <label><input type="checkbox" name="playerId" value="<%= player.id %>"><span><strong><%= player.displayName %></strong><small><%= player.email || 'Chưa có email' %></small></span></label>
              <% }) %>
            </div>
            <button class="btn btn-success" data-loading-text="Đang thêm...">Thêm người đã chọn</button>
          </form>
        <% } %>
        <form class="travel-member-form mb" method="post" action="/travel/trips/<%= trip.id %>/members">
          <div><label>Thêm nhanh (ngoài danh sách)</label><input name="name" placeholder="Tên thành viên"></div>
          <div><label>Email</label><input name="email" type="email" placeholder="Có email sẽ tự lưu vào danh sách chung"></div>
          <button class="btn btn-outline" data-loading-text="Đang thêm...">Thêm nhanh</button>
        </form>
        <% if (members.length) { %>
          <form id="tmBulkDelete" method="post" action="/travel/trips/<%= trip.id %>/members/bulk-delete" data-require-checked="memberId" data-confirm="Xóa những thành viên đã chọn?"></form>
          <div class="travel-member-list">
            <% members.forEach((member) => { %>
              <form class="travel-member-row" method="post" action="/travel/trips/<%= trip.id %>/members/<%= member.id %>/edit">
                <input type="checkbox" form="tmBulkDelete" name="memberId" value="<%= member.id %>" aria-label="Chọn <%= member.name %>">
                <div><input name="name" value="<%= member.name %>" required></div>
                <div><input name="email" type="email" value="<%= member.email %>" placeholder="Email"></div>
                <button class="btn btn-sm" data-loading-text="Đang lưu...">Lưu</button>
                <button class="btn btn-sm btn-danger" formaction="/travel/trips/<%= trip.id %>/members/<%= member.id %>/delete" data-confirm="Xóa thành viên này?" data-loading-text="Đang xóa...">Xóa</button>
              </form>
            <% }) %>
          </div>
          <div class="text-right mt"><button class="btn btn-danger btn-sm" form="tmBulkDelete" data-loading-text="Đang xóa...">🗑️ Xóa người đã chọn</button></div>
        <% } else { %>
          <p class="muted">Chưa có thành viên. Thêm từ danh sách hoặc nhập nhanh phía trên.</p>
        <% } %>
      </section>
    <% } else { %>
      <section class="card-lite p mb">
        <div class="section-heading mb"><div><span class="feature-icon">👥</span><h2 class="section-title">Thành viên</h2></div></div>
        <div class="travel-table-wrap">
          <table class="travel-table">
            <thead><tr><th>Thành viên</th><th>Đã thu</th><th>Đã trả</th><th>Ứng trước</th><th>Còn thiếu</th></tr></thead>
            <tbody>
              <% members.forEach((member) => { const key = member.id.toString(); const isTreasurer = String(trip.treasurerMemberId || '') === key; %>
                <tr class="<%= String(viewerMemberId || '') === key ? 'mine-row' : '' %>">
                  <td><strong><%= member.name %></strong><% if (isTreasurer) { %><br><span class="badge">Thủ quỹ</span><% } %></td>
                  <td><%= formatMoney(isTreasurer ? (summary.memberSpent.get(key) || 0) : (summary.actualCollected.get(key) || 0)) %>đ</td>
                  <td><strong><%= formatMoney(summary.memberPaidTotal.get(key) || 0) %>đ</strong></td>
                  <td><strong class="text-success"><%= formatMoney(summary.memberAdvanced.get(key) || 0) %>đ</strong></td>
                  <td><strong class="<%= (summary.memberDebt.get(key) || 0) > 0 ? 'text-danger' : 'text-success' %>"><%= formatMoney(summary.memberDebt.get(key) || 0) %>đ</strong></td>
                </tr>
              <% }) %>
              <% if (!members.length) { %><tr><td colspan="5" class="text-center muted">Chưa có thành viên.</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </section>
    <% } %>
  <% } %>

  <!-- ===== KHOẢN CHI ===== -->
  <% if (section === 'expenses') { %>
    <% if (isTravelAdmin) { %>
      <section class="card-lite p mb">
        <div class="section-heading mb"><div><span class="feature-icon">➕</span><h2 class="section-title">Thêm khoản chi</h2></div></div>
        <% if (!members.length) { %>
          <p class="muted">Cần thêm thành viên trước khi ghi khoản chi.</p>
        <% } else { %>
        <form class="travel-expense-form" method="post" action="/travel/trips/<%= trip.id %>/expenses">
          <div><label>Ngày chi</label><input type="date" name="spentDate" value="<%= today %>"></div>
          <div><label>Nội dung</label><select name="title"><% expenseCategories.forEach((category) => { %><option value="<%= category %>"><%= category %></option><% }) %></select></div>
          <div><label>Số tiền</label><input class="money-input" name="amount" placeholder="0"></div>
          <div><label>Người trả</label><select name="paidByMemberId" required><% members.forEach((member) => { %><option value="<%= member.id %>" <%= String(trip.treasurerMemberId || '') === String(member.id) ? 'selected' : '' %>><%= member.name %></option><% }) %></select></div>
          <div><label>Kiểu chia</label><select name="splitMode" data-travel-split-mode><option value="SHARED">Chia đều</option><option value="PRIVATE">Chi riêng</option></select></div>
          <div class="travel-expense-note"><label>Ghi chú</label><input name="note" placeholder="Tên khách sạn, quán ăn, địa chỉ..."></div>
          <div class="travel-private-grid" data-travel-private-grid>
            <% members.forEach((member) => { %><label><span><%= member.name %></span><input class="money-input" name="privateSplit_<%= member.id %>" placeholder="0"></label><% }) %>
          </div>
          <button class="btn btn-success" data-loading-text="Đang thêm...">Thêm khoản chi</button>
        </form>
        <% } %>
      </section>
    <% } %>

    <section class="card-lite p mb">
      <div class="section-heading mb"><div><span class="feature-icon">📋</span><h2 class="section-title">Bảng khoản chi</h2><% if (isTravelAdmin) { %><p class="muted">Sửa số tiền/chia ngay trong ô rồi bấm Lưu.</p><% } %></div><span class="badge"><%= expenses.length %> khoản</span></div>
      <% if (isTravelAdmin) { expenses.forEach((expense) => { %>
        <form id="exp-<%= expense.id %>" method="post" action="/travel/trips/<%= trip.id %>/expenses/<%= expense.id %>/edit">
          <input type="hidden" name="title" value="<%= expense.title %>">
          <input type="hidden" name="spentDate" value="<%= expense.spentDate ? new Date(expense.spentDate).toISOString().slice(0,10) : today %>">
          <input type="hidden" name="paidByMemberId" value="<%= expense.paidByMemberId || '' %>">
          <input type="hidden" name="note" value="<%= expense.note %>">
        </form>
      <% }) } %>
      <div class="travel-frozen-wrap">
        <table class="travel-table travel-table-sticky travel-expense-table">
          <thead><tr><th class="sticky-col">Khoản chi</th><th>Người trả</th><th>Tổng</th><% members.forEach((member) => { %><th><%= member.name %></th><% }) %><% if (isTravelAdmin) { %><th>Thao tác</th><% } %></tr></thead>
          <tbody>
            <% expenses.forEach((expense) => { const splitMap = new Map(expense.splits.map((split) => [split.memberId.toString(), Number(split.amount)])); %>
              <tr>
                <td class="sticky-col"><strong><%= expense.title %></strong><br><span class="muted"><%= expense.spentDate ? new Date(expense.spentDate).toLocaleDateString('vi-VN') : '-' %> · <%= expense.note || 'Không ghi chú' %></span></td>
                <td><%= expense.paidByMember?.name || '-' %></td>
                <% if (isTravelAdmin) { %>
                  <td><input class="money-input" form="exp-<%= expense.id %>" name="amount" value="<%= formatMoney(expense.amount) %>"></td>
                  <% members.forEach((member) => { const key = member.id.toString(); %><td><input class="money-input" form="exp-<%= expense.id %>" name="split_<%= key %>" value="<%= formatMoney(splitMap.get(key) || 0) %>"></td><% }) %>
                  <td class="travel-exp-actions"><button class="btn btn-sm btn-success" form="exp-<%= expense.id %>" data-loading-text="...">Lưu</button><button class="btn btn-sm btn-danger" form="exp-<%= expense.id %>" formaction="/travel/trips/<%= trip.id %>/expenses/<%= expense.id %>/delete" data-confirm="Xóa khoản chi này?" data-loading-text="...">Xóa</button></td>
                <% } else { %>
                  <td><strong><%= formatMoney(expense.amount) %>đ</strong></td>
                  <% members.forEach((member) => { const key = member.id.toString(); %><td class="<%= String(viewerMemberId || '') === key ? 'mine-row' : '' %>"><%= formatMoney(splitMap.get(key) || 0) %>đ</td><% }) %>
                <% } %>
              </tr>
            <% }) %>
            <% if (!expenses.length) { %><tr><td colspan="<%= 3 + members.length + (isTravelAdmin ? 1 : 0) %>" class="text-center muted">Chưa có khoản chi.</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </section>
  <% } %>

  <!-- ===== AI GỢI Ý ===== -->
  <% if (section === 'ai') { %>
    <section class="card-lite p mb">
      <div class="section-heading mb"><div><span class="feature-icon">🤖</span><h2 class="section-title">Gợi ý &amp; lịch trình bằng AI</h2><p class="muted">AI gợi ý địa điểm và lịch trình cho <strong><%= trip.destination?.name || trip.name %></strong>. Chỉ mang tính tham khảo, nên kiểm chứng lại giờ mở cửa/địa chỉ.</p></div></div>
      <% if (aiError) { %><div class="alert-lite warn mb">⚠️ <%= aiError %></div><% } %>
      <% if (isTravelAdmin) { %>
        <% if (!aiConfigured) { %>
          <div class="alert-lite warn mb">Chưa cấu hình <code>GEMINI_API_KEY</code> trên server nên chưa tạo được gợi ý AI.</div>
        <% } %>
        <form class="travel-member-form mb" method="post" action="/travel/trips/<%= trip.id %>/ai-plan">
          <div><label>Số ngày</label><input name="days" type="number" min="1" max="10" value="2"></div>
          <div><label>Số người</label><input name="people" type="number" min="1" value="<%= members.length || 1 %>"></div>
          <div><label>Sở thích/ghi chú</label><input name="notes" placeholder="Có trẻ em, thích hải sản, ngân sách vừa..."></div>
          <button class="btn btn-success" data-loading-text="Đang hỏi AI..." <%= aiConfigured ? '' : 'disabled' %>>✨ Tạo gợi ý AI</button>
        </form>
      <% } %>
      <% if (aiPlan) { %>
        <% if (aiPlan.summary) { %><p class="mb"><strong>Tổng quan:</strong> <%= aiPlan.summary %></p><% } %>
        <% const byCat = {}; (aiPlan.places || []).forEach((p) => { (byCat[p.category] = byCat[p.category] || []).push(p); }); %>
        <% Object.keys(byCat).forEach((cat) => { %>
          <div class="mb"><h3 class="section-title" style="font-size:17px">📍 <%= cat %></h3>
            <div class="grid travel-place-grid">
              <% byCat[cat].forEach((place) => { %>
                <div class="travel-place-card"><div class="travel-place-icon">📌</div><div><h3><%= place.name %></h3><% if (place.area) { %><span class="badge"><%= place.area %></span><% } %><p class="muted"><%= place.note %></p></div></div>
              <% }) %>
            </div>
          </div>
        <% }) %>
        <% if ((aiPlan.itinerary || []).length) { %>
          <h3 class="section-title mt" style="font-size:17px">🗓️ Lịch trình gợi ý</h3>
          <% aiPlan.itinerary.forEach((day) => { %>
            <div class="card-lite p mb"><strong><%= day.day %></strong>
              <div class="table-wrap"><table class="travel-table"><thead><tr><th>Khung giờ</th><th>Hoạt động</th><th>Ghi chú</th></tr></thead><tbody>
                <% (day.slots || []).forEach((slot) => { %><tr><td><strong><%= slot.time %></strong></td><td><%= slot.activity %></td><td class="muted"><%= slot.note %></td></tr><% }) %>
              </tbody></table></div>
            </div>
          <% }) %>
        <% } %>
      <% } else if (aiConfigured || !isTravelAdmin) { %>
        <p class="muted text-center">Chưa có gợi ý AI cho chuyến này<%= isTravelAdmin ? '. Bấm "Tạo gợi ý AI" ở trên.' : '.' %></p>
      <% } %>
    </section>
  <% } %>

  <!-- ===== GỢI Ý ĐỊA ĐIỂM ===== -->
  <% if (hasPlaces && section === 'places') { %>
    <section class="card-lite p mb">
      <div class="section-heading mb"><div><span class="feature-icon">🧭</span><h2 class="section-title">Gợi ý tại <%= trip.destination.name %></h2></div></div>
      <div class="grid travel-place-grid">
        <% destinationSuggestions.forEach((suggestion) => { %>
          <div class="travel-place-card">
            <div class="travel-place-icon"><%= suggestion.category === 'Quán ăn ngon' ? '🍜' : suggestion.category === 'Cà phê đẹp' ? '☕' : suggestion.category === 'Khách sạn tốt' ? '🏨' : suggestion.category === 'Vui chơi' ? '🎡' : suggestion.category === 'Thể thao' ? '🏃' : '🧭' %></div>
            <div><span class="badge"><%= suggestion.category %></span><h3><%= suggestion.name %></h3><p class="muted"><%= suggestion.address || suggestion.description || 'Chưa có mô tả' %></p></div>
          </div>
        <% }) %>
      </div>
    </section>
  <% } %>

  <!-- ===== CÀI ĐẶT ===== -->
  <% if (isTravelAdmin && section === 'settings') { %>
    <section class="card-lite p mb">
      <div class="section-heading mb"><div><span class="feature-icon">⚙️</span><h2 class="section-title">Cấu hình chuyến</h2></div></div>
      <form class="travel-trip-form" method="post" action="/travel/trips/<%= trip.id %>/edit">
        <div><label>Tên chuyến</label><input name="name" value="<%= trip.name %>" required></div>
        <div><label>Địa danh có sẵn</label><select name="destinationId"><option value="">Chọn sau</option><% destinations.forEach((destination) => { %><option value="<%= destination.id %>" <%= String(trip.destinationId || '') === String(destination.id) ? 'selected' : '' %>><%= destination.name %></option><% }) %></select></div>
        <div><label>Địa danh mới</label><input name="destinationName" placeholder="Tạo nhanh nếu chưa có"></div>
        <div><label>Ghi chú</label><input name="description" value="<%= trip.description %>"></div>
        <div class="travel-trip-action"><button class="btn btn-success" data-loading-text="Đang lưu...">Lưu</button></div>
      </form>
    </section>
    <section class="card-lite p">
      <div class="section-heading mb"><div><span class="feature-icon">🗑️</span><h2 class="section-title">Xóa chuyến</h2><p class="muted">Ẩn chuyến khỏi danh sách, không xóa vĩnh viễn dữ liệu.</p></div></div>
      <form method="post" action="/travel/trips/<%= trip.id %>/delete" data-confirm="Xóa chuyến đi này?"><button class="btn btn-danger" data-loading-text="Đang xóa...">Xóa chuyến đi</button></form>
    </section>
  <% } %>
</main>

<nav class="bottom-menu">
  <button class="mobile-menu-toggle" type="button" data-menu-toggle aria-label="Mở menu">☰</button>
  <div class="bottom-menu-inner">
    <% sections.forEach((item) => { %><a class="<%= section === item.key ? 'active' : '' %>" href="/travel/trips/<%= trip.id %>/<%= item.key %>"><%= item.label %></a><% }) %>
  </div>
</nav>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/app.js"></script>
<script src="/js/form-controls.js"></script>
<script src="/js/selection-controls.js"></script>
<script src="/js/menu.js"></script>
<script src="/js/modal-copy.js"></script>
<script src="/js/realtime.js"></script>
<script src="/js/travel.js"></script>
</body>
</html>
