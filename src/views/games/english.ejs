<%- include('../partials/head', { title: 'Tiếng Anh vui' }) %>
<body class="game-body">
  <div class="game-stage game-stage-english" data-game="english">
    <header class="game-topbar">
      <a class="game-back" href="/games">Về</a>
      <div class="game-hud">
        <span class="game-stat">⭐ <b data-score>0</b></span>
        <span class="game-stat">🔥 <b data-streak>0</b></span>
        <span class="game-stat">🏆 <b data-best>0</b></span>
      </div>
    </header>

    <div class="game-levels" data-levels>
      <button class="game-level active" data-cat="all">🌈 Tất cả</button>
      <button class="game-level" data-cat="animals">🐶 Con vật</button>
      <button class="game-level" data-cat="fruits">🍎 Trái cây</button>
      <button class="game-level" data-cat="colors">🎨 Màu sắc</button>
      <button class="game-level" data-cat="things">🚗 Đồ vật</button>
    </div>

    <div class="game-panel">
      <div class="game-visual game-visual-word" data-visual></div>
      <button class="game-speak" data-speak type="button">🔊 Nghe đọc</button>
      <div class="game-question" data-question></div>
      <div class="game-choices" data-choices></div>
      <div class="game-feedback" data-feedback></div>
    </div>
  </div>
  <script src="/js/games-core.js"></script>
  <script src="/js/games-english.js"></script>
</body>
</html>
