<%- include('../partials/head', { title: 'Theo dõi log' }) %>
<%- include('../partials/topbar') %>
<%
  const levelLabels = { ERROR: 'Lỗi', WARN: 'Cảnh báo', INFO: 'Thông tin', ALL: 'Tất cả' };
  const roleLabels = { ADMIN: 'Quản trị', CLIENT: 'Khách xem' };
  const categoryLabels = { HTTP: 'Truy cập' };
  categoryLabels.REDIS = 'Redis';
%>
<main class="app-shell">
  <section class="card-lite p mb"><div class="flex between center"><div><h1>Theo dõi log hệ thống</h1><p class="muted">Thời gian hiển thị theo giờ Việt Nam.</p></div><div class="flex gap"><% levels.forEach((item) => { %><a class="btn btn-sm <%= level === item ? 'btn-primary' : '' %>" href="/logs?level=<%= item %>"><%= levelLabels[item] || item %></a><% }) %></div></div></section>
  <section class="card-lite table-wrap"><table><thead><tr><th>Thời gian</th><th>Mức</th><th>Tài khoản</th><th>Thao tác</th><th>Yêu cầu</th><th>Chi tiết</th><th>Lỗi</th></tr></thead><tbody>
    <% logs.forEach((log) => { const created = new Date(log.createdAt); const vn = created.toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh', hour12: false }); %>
      <tr><td><%= vn %></td><td><span class="badge <%= log.level === 'ERROR' ? 'badge-danger' : (log.level === 'WARN' ? 'badge-warn' : '') %>"><%= levelLabels[log.level] || log.level %></span></td><td><%= log.username || 'Chưa đăng nhập' %><br><span class="muted"><%= roleLabels[log.userRole] || '' %></span></td><td><strong><%= categoryLabels[log.category] || log.category %></strong><br><%= log.action %></td><td><%= log.method || '' %> <%= log.path || '' %><br><span class="muted"><%= log.statusCode || '-' %> · <%= log.durationMs || '-' %>ms</span></td><td><%= log.details || '' %></td><td class="muted"><%= log.errorMessage || '' %></td></tr>
    <% }) %>
  </tbody></table></section>
</main>
<%- include('../partials/bottom-menu') %>
