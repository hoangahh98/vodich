<nav class="bottom-menu">
  <button class="mobile-menu-toggle" type="button" data-menu-toggle aria-label="Mở menu">☰</button>
  <div class="bottom-menu-inner">
    <% const currentPath = path || '/'; %>
    <% if (currentPath === '/') { %>
      <a class="" href="/score-reader">🔊 Đọc điểm</a>
      <a class="" href="/games">🎮 Học vui</a>
      <% if (featureSet.has('TOURNAMENTS')) { %><a class="" href="/tournaments">🏆 Giải đấu</a><% } %>
      <% if (featureSet.has('TEAMS')) { %><a class="" href="/teams"><span class="pickleball-icon" aria-hidden="true"></span> Đội bóng</a><% } %>
      <% if (featureSet.has('TRAVEL')) { %><a class="" href="/travel">🌴 Du lịch</a><% } %>
      <% if (featureSet.has('MEDICAL')) { %><a class="" href="/medical">🩺 Y tế</a><% } %>
      <% if (featureSet.has('HOUSEHOLD')) { %><a class="" href="/household">💰 Chi tiêu</a><% } %>
      <% if (featureSet.has('PERMISSIONS')) { %><a class="" href="/permissions">🔐 Phân quyền</a><% } %>
      <% if (isRoot) { %><a class="" href="/logs">📜 Log</a><% } %>
    <% } else { %>
      <%# Menu theo từng mục chỉ liệt kê trang trong mục đó, nên phải có lối về trang chủ
          để còn sang module khác, nếu không menu thành ngõ cụt. %>
      <a class="" href="/">🏠 Trang chủ</a>
    <% } %>
    <% if (currentPath === '/') { %>
    <% } else if ((currentPath.startsWith('/tournaments') || currentPath.startsWith('/players')) && featureSet.has('TOURNAMENTS')) { %>
      <a class="<%= currentPath.startsWith('/tournaments') ? 'active' : '' %>" href="/tournaments">🏆 Giải đấu</a>
      <% if (currentUser && currentUser.role === 'ADMIN') { %><a class="<%= currentPath.startsWith('/players') ? 'active' : '' %>" href="/players">👥 Thành viên</a><% } %>
    <% } else if (currentPath.startsWith('/teams') && featureSet.has('TEAMS')) { %>
      <a class="active" href="/teams"><span class="pickleball-icon" aria-hidden="true"></span> Đội bóng</a>
    <% } else if (currentPath.startsWith('/travel') && featureSet.has('TRAVEL')) { %>
      <a class="active" href="/travel">🌴 Du lịch</a>
    <% } else if (currentPath.startsWith('/medical') && featureSet.has('MEDICAL')) { %>
      <%# Điều hướng y tế nằm hết ở đây, không dùng nút mũi tên trong trang. %>
      <a class="<%= currentPath === '/medical' ? 'active' : '' %>" href="/medical">🩺 Danh sách</a>
      <% if (typeof menuPatientId !== 'undefined' && menuPatientId) { %>
        <a class="<%= currentPath.startsWith('/medical/patients/') ? 'active' : '' %>" href="/medical/patients/<%= menuPatientId %>">💊 Đơn thuốc</a>
      <% } %>
      <% if (typeof menuPrescriptionId !== 'undefined' && menuPrescriptionId) { %>
        <a class="<%= currentPath.includes('/lich') ? 'active' : '' %>" href="/medical/prescriptions/<%= menuPrescriptionId %>/lich">📅 Lịch uống</a>
      <% } %>
    <% } else if (currentPath.startsWith('/household') && featureSet.has('HOUSEHOLD')) { %>
      <a class="<%= currentPath === '/household' ? 'active' : '' %>" href="/household">📊 Tổng quan</a>
      <a class="<%= currentPath === '/household/giao-dich' ? 'active' : '' %>" href="/household/giao-dich">🧾 Giao dịch</a>
      <a class="<%= currentPath === '/household/tiet-kiem' ? 'active' : '' %>" href="/household/tiet-kiem">🐷 Tiết kiệm</a>
      <a class="<%= currentPath === '/household/cau-hinh' ? 'active' : '' %>" href="/household/cau-hinh">⚙️ Cấu hình</a>
    <% } else if (currentPath.startsWith('/permissions') && featureSet.has('PERMISSIONS')) { %>
      <a class="active" href="/permissions">🔐 Phân quyền</a>
    <% } else if (currentPath.startsWith('/logs') && isRoot) { %>
      <a class="active" href="/logs">📜 Log</a>
    <% } else if (currentPath.startsWith('/score-reader') || currentPath.startsWith('/doc-diem-giao-luu')) { %>
      <a class="active" href="/score-reader">🔊 Đọc điểm</a>
    <% } %>
  </div>
</nav>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/app.js"></script>
<script src="/js/form-controls.js"></script>
<script src="/js/selection-controls.js"></script>
<script src="/js/menu.js"></script>
<script src="/js/modal-copy.js"></script>
<script src="/js/realtime.js"></script>
</body>
</html>
