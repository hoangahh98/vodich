<%- include('../partials/head', { title: team.name }) %>
<%- include('../partials/topbar') %>
<% const currentEmail = String(currentUser?.email || currentUser?.username || '').toLowerCase(); %>
<% const isMine = (member) => String(member.player.email || '').toLowerCase() === currentEmail; %>
<main class="app-shell team-detail-shell" data-team-id="<%= team.id %>">
  <section class="feature-hero p mb">
    <div class="flex between center">
      <div>
        <h1><%= team.name %></h1>
        <div class="muted strong-muted"><%= team.description || 'Chưa có ghi chú' %></div>
      </div>
      <form method="get" action="/teams/<%= team.id %>/<%= section %>" class="month-filter">
        <label>Tháng quỹ</label>
        <input type="month" name="month" value="<%= selectedMonth %>" onchange="this.form.submit()">
      </form>
    </div>
  </section>

  <% if (section === 'overview') { %>
    <section class="grid finance-grid mb">
      <div class="metric-card blue"><span>💰 Tổng thu</span><strong><%= formatMoney(finance.totalPaid) %>đ</strong><small>Còn <%= finance.fixedUnpaidCount %> người cố định chưa đóng</small></div>
      <div class="metric-card green"><span>🎁 Tổng donate</span><strong>+<%= formatMoney(finance.totalDonate) %>đ</strong><small>Vượt mức <%= formatMoney(finance.monthlyFee) %>đ/người</small></div>
      <div class="metric-card orange"><span>🏟️ Tiền sân</span><strong><%= formatMoney(finance.courtCost) %>đ</strong><small>Dư trước <%= formatMoney(finance.previousBalance) %>đ</small></div>
      <div class="metric-card gold"><span>🧾 Quỹ còn lại</span><strong><%= formatMoney(finance.balance) %>đ</strong><small>= Dư + Thu - Sân - Chi</small></div>
    </section>

    <section class="card-lite mb">
      <div class="card-hdr blue"><span>🧾 Các khoản chi tháng <%= selectedMonth %></span><span><%= formatMoney(finance.totalExpense) %>đ</span></div>
        <div class="p">
          <% if (currentUser.role === 'ADMIN') { %>
            <form class="team-expense-form mb" method="post" action="/teams/<%= team.id %>/expenses">
              <input type="hidden" name="month" value="<%= selectedMonth %>">
              <div class="expense-date"><label>Ngày chi</label><input type="date" name="expenseDate" required></div>
              <div class="expense-content"><label>Nội dung</label><input name="content" placeholder="Uống nước, bóng..." required></div>
              <div class="expense-amount"><label>Số tiền</label><input class="money-input" name="amount" required></div>
              <div class="expense-action"><button class="btn btn-success" data-loading-text="Đang thêm...">Thêm</button></div>
            </form>
          <% } %>
          <div class="table-wrap team-frozen-wrap"><table><thead><tr><th>Ngày</th><th>Nội dung</th><th>Tiền</th><th></th></tr></thead><tbody>
            <% expenses.forEach((expense) => { %>
              <tr><td><%= expense.expenseDate ? new Date(expense.expenseDate).toLocaleDateString('vi-VN') : '-' %></td><td><strong><%= expense.content %></strong><% if (expense.notes) { %><br><span class="muted"><%= expense.notes %></span><% } %></td><td><strong><%= formatMoney(expense.amount) %>đ</strong></td><td class="text-right"><% if (currentUser.role === 'ADMIN') { %><form method="post" action="/teams/<%= team.id %>/expenses/<%= expense.id %>/delete" data-confirm="Xóa khoản chi này?"><input type="hidden" name="month" value="<%= selectedMonth %>"><button class="btn btn-sm btn-danger" data-loading-text="Đang xóa...">Xóa</button></form><% } %></td></tr>
            <% }) %>
            <% if (!expenses.length) { %><tr><td colspan="4" class="muted text-center">Chưa có khoản chi nào trong tháng.</td></tr><% } %>
          </tbody></table></div>
        </div>
    </section>
  <% } %>

  <% if (section === 'members') { %>
    <section class="card-lite p">
      <div class="section-heading mb">
        <div><span class="feature-icon">👥</span><h2 class="section-title">Thành viên và đóng phí</h2><p class="muted">Danh sách đóng phí nằm ngay trong mục thành viên.</p></div>
        <% if (currentUser.role === 'ADMIN' && members.length) { %><button class="btn btn-sm btn-outline" type="button" data-open-modal="teamEmailModal">Get Email</button><% } %>
      </div>
      <% if (currentUser.role === 'ADMIN') { %>
        <form class="registration-panel mb" method="post" action="/teams/<%= team.id %>/members" data-require-checked="playerIds">
          <input type="hidden" name="month" value="<%= selectedMonth %>">
          <div class="player-check-list team-member-picker mb" data-team-member-picker>
            <% players.forEach((p) => { %>
              <label><input type="checkbox" name="playerIds" value="<%= p.id %>"><span><strong><%= p.displayName %></strong><small><%= p.email %> · <%= p.skillLevel || 'Chưa chọn trình' %></small></span></label>
            <% }) %>
            <% if (!players.length) { %><div class="muted p">Không còn thành viên nào để thêm vào đội này.</div><% } %>
          </div>
          <div class="flex between center gap team-member-actions">
            <span class="muted" data-team-member-count>Đã chọn 0 thành viên</span>
            <div class="flex gap">
              <select name="memberType" class="team-member-type"><option value="FIXED">Cố định</option><option value="GUEST">Vãng lai</option></select>
              <input name="notes" placeholder="Ghi chú">
              <button class="btn btn-primary" data-loading-text="Đang thêm...">Thêm đã chọn</button>
            </div>
          </div>
        </form>

        <% if (members.length) { %>
          <details class="team-fee-edit mb">
            <summary>✏️ Cập nhật phí tất cả thành viên</summary>
            <form method="post" action="/teams/<%= team.id %>/payments">
              <input type="hidden" name="month" value="<%= selectedMonth %>">
              <div class="table-wrap team-frozen-wrap"><table class="team-fee-table team-fee-edit-table"><thead><tr><th class="sticky-col">Thành viên</th><th>Loại</th><th>Số tiền</th><th>Trạng thái</th><th>Ghi chú phí</th></tr></thead><tbody>
                <% members.forEach((member) => { %>
                  <tr>
                    <td class="sticky-col"><strong><%= member.player.displayName %></strong><br><span class="muted"><%= member.typeLabel %></span></td>
                    <td><select name="memberType_<%= member.id %>"><option value="FIXED" <%= member.memberType === 'FIXED' ? 'selected' : '' %>>Cố định</option><option value="GUEST" <%= member.memberType === 'GUEST' ? 'selected' : '' %>>Vãng lai</option></select></td>
                    <td><input class="money-input" name="amount_<%= member.id %>" value="<%= formatMoney(member.enteredAmount) %>"></td>
                    <td><select class="payment-status-select" name="status_<%= member.id %>"><option value="UNPAID" <%= member.paymentStatus !== 'PAID' ? 'selected' : '' %>>✕</option><option value="PAID" <%= member.paymentStatus === 'PAID' ? 'selected' : '' %>>✓</option></select></td>
                    <td><input name="notes_<%= member.id %>" value="<%= member.feeNotes %>" placeholder="Ghi chú"></td>
                  </tr>
                <% }) %>
              </tbody></table></div>
              <div class="mt text-right"><button class="btn btn-primary" data-loading-text="Đang lưu...">Lưu tất cả (<%= members.length %> thành viên)</button></div>
            </form>
          </details>
        <% } %>
      <% } %>

      <div class="table-wrap team-frozen-wrap"><table class="team-fee-table team-member-fee-list"><thead><tr><th class="sticky-col">Tên</th><th>Loại</th><th>Tiền đóng</th><th>Trạng thái</th><th>Donate/thiếu</th></tr></thead><tbody>
        <% members.forEach((member) => { %>
          <tr class="<%= isMine(member) ? 'mine-row' : '' %> <%= member.paymentStatus === 'PAID' ? 'sufficient-row' : 'insufficient-row' %>">
            <td class="sticky-col"><strong><%= member.player.displayName %></strong><% if (member.notes) { %><br><span class="muted"><%= member.notes %></span><% } %></td>
            <td><span class="badge <%= member.memberType === 'GUEST' ? 'bg-info text-dark' : 'bg-success' %>"><%= member.typeLabel %></span></td>
            <td><strong><%= formatMoney(member.paidAmount) %>đ</strong></td>
            <td><span class="payment-mark <%= member.paymentStatus === 'PAID' ? 'paid' : 'unpaid' %>"><%= member.paymentStatus === 'PAID' ? '✓' : '✕' %></span></td>
            <td>
              <% if (member.memberType === 'GUEST') { %><span class="muted">-</span>
              <% } else if (member.difference > 0) { %><span class="badge bg-success">+<%= formatMoney(member.difference) %>đ donate</span>
              <% } else if (member.difference === 0 && finance.monthlyFee > 0) { %><span class="badge bg-primary">Đủ phí</span>
              <% } else { %><span class="badge bg-danger">Thiếu <%= formatMoney(Math.abs(member.difference)) %>đ</span><% } %>
              <% if (member.feeNotes) { %><br><span class="muted"><%= member.feeNotes %></span><% } %>
            </td>
          </tr>
        <% }) %>
        <% if (!members.length) { %><tr><td colspan="5" class="muted text-center">Chưa có thành viên nào trong đội.</td></tr><% } %>
      </tbody></table></div>
    </section>
  <% } %>

  <% if (section === 'settings') { %>
    <section class="card-lite p tournament-edit-card">
      <div class="section-heading mb"><div><span class="feature-icon">⚙️</span><h2 class="section-title">Cài đặt đội bóng</h2><p class="muted">Sửa thông tin đội và cấu hình quỹ tháng.</p></div></div>
      <% if (currentUser.role === 'ADMIN') { %>
        <form class="tournament-form" method="post" action="/teams/<%= team.id %>/settings">
          <input type="hidden" name="month" value="<%= selectedMonth %>">
          <section class="form-section">
            <h2 class="section-title mb">👥 Thông tin đội</h2>
            <div class="row">
              <div class="col-12"><label>Tên đội bóng</label><input name="name" value="<%= team.name %>" required></div>
              <div class="col-12"><label>Ghi chú đội</label><textarea name="description" rows="3"><%= team.description || '' %></textarea></div>
            </div>
          </section>
          <section class="form-section">
            <h2 class="section-title mb">💰 Quỹ tháng <%= selectedMonth %></h2>
            <div class="row">
              <div class="col-6"><label>Mức phí tháng / người</label><input class="money-input" name="monthlyFee" value="<%= formatMoney(finance.monthlyFee) %>"></div>
              <div class="col-6"><label>Tiền sân tháng này</label><input class="money-input" name="courtCost" value="<%= formatMoney(finance.courtCost) %>"></div>
              <div class="col-6"><label>Tiền sân còn lại tháng trước</label><input class="money-input" name="previousBalance" value="<%= formatMoney(finance.previousBalance) %>"><small class="muted">Tháng trước còn lại <%= formatMoney(finance.previousMonthBalance) %>đ. Nếu để trống, hệ thống tự dùng số này.</small></div>
              <div class="col-6"><label>Ghi chú tháng</label><input name="notes" value="<%= fund?.notes || '' %>"></div>
            </div>
          </section>
          <div class="form-actions"><button class="btn btn-success btn-lg" data-loading-text="Đang lưu...">Lưu thay đổi</button><a class="btn btn-lg" href="/teams/<%= team.id %>/overview?month=<%= selectedMonth %>">Hủy</a></div>
        </form>
      <% } else { %>
        <div class="grid team-summary-grid">
          <div class="cost-card">👥<span>Tên đội</span><strong><%= team.name %></strong></div>
          <div class="cost-card">📝<span>Ghi chú</span><strong><%= team.description || '-' %></strong></div>
        </div>
      <% } %>
    </section>
  <% } %>

  <% if (currentUser.role === 'ADMIN') { %>
    <div id="teamEmailModal" class="score-modal hidden" aria-hidden="true">
      <div class="score-modal-backdrop" data-close-modal="teamEmailModal"></div>
      <div class="score-modal-panel" role="dialog" aria-modal="true">
        <div class="score-modal-head"><div><h3>Danh sách email</h3><small>Copy email thành viên đội bóng</small></div><button class="btn btn-sm" type="button" data-close-modal="teamEmailModal">Đóng</button></div>
        <div class="score-modal-body">
          <textarea id="teamEmailListText" rows="6" readonly><%= emailList %></textarea>
          <div class="mt text-right"><button class="btn btn-primary" type="button" data-copy-target="teamEmailListText">Copy email</button></div>
        </div>
      </div>
    </div>
  <% } %>
</main>

<nav class="bottom-menu"><button class="mobile-menu-toggle" type="button" data-menu-toggle aria-label="Mở menu">☰</button><div class="bottom-menu-inner">
  <% (currentUser.role === 'ADMIN' ? ['overview','members','settings'] : ['overview','members']).forEach((item) => { const labels = {overview:'📊 Tổng quan', members:'👥 Thành viên', settings:'⚙️ Cài đặt'}; %><a class="<%= section === item ? 'active' : '' %>" href="/teams/<%= team.id %>/<%= item %>?month=<%= selectedMonth %>"><%= labels[item] %></a><% }) %>
</div></nav>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
