<%- include('../partials/head', { title: 'Lịch uống thuốc - ' + patient.name }) %>
<%- include('../partials/topbar') %>
<%
  const WEEKDAYS = ['Chủ nhật', 'Thứ 2', 'Thứ 3', 'Thứ 4', 'Thứ 5', 'Thứ 6', 'Thứ 7'];
  const viDate = (iso) => {
    const [y, m, d] = iso.split('-');
    return `${WEEKDAYS[new Date(`${iso}T00:00:00Z`).getUTCDay()]}, ${d}/${m}`;
  };
  // Gom các cữ theo ngày để hiện thành từng khối cho dễ đọc trên điện thoại.
  const byDate = new Map();
  result.groups.forEach((g) => {
    if (!byDate.has(g.date)) byDate.set(g.date, []);
    byDate.get(g.date).push(g);
  });
  // Tóm tắt theo THUỐC: mỗi thuốc uống mấy giờ, từ ngày nào đến ngày nào.
  // Danh sách 36 cữ trải dài cả chục màn hình, nhìn không ra thuốc nào hết ngày nào.
  const byDrug = new Map();
  result.groups.forEach((g) => {
    g.lines.forEach((line) => {
      // Gom theo ID THUỐC chứ không theo tên: sau khi chuyển đơn có thể có hai dòng cùng
      // tên (một cái kê mới, một cái chuyển sang). Gom theo tên là nhập chúng làm một và
      // che mất chuyện đang bị kê trùng.
      if (!byDrug.has(line.itemId)) byDrug.set(line.itemId, { line, times: new Set(), first: g.date, last: g.date, doses: 0 });
      const entry = byDrug.get(line.itemId);
      entry.times.add(g.time);
      if (g.date < entry.first) entry.first = g.date;
      if (g.date > entry.last) entry.last = g.date;
      entry.doses++;
    });
  });
  const q = `start=${startDate}&slot=${startSlot}`;
  const icsUrl = `/medical/prescriptions/${prescription.id}/lich.ics?${q}`;
  const icsFullUrl = `${icsUrl}&full=1`;
  const isConfirmed = Boolean(confirmedStart);
  // Số thuốc chuyển sang từ đơn cũ. Bằng 0 thì cả đơn là thuốc mới -> không dán nhãn gì cả.
  const carriedCount = [...byDrug.values()].filter((e) => drugSources.has(e.line.itemId)).length;
  // Lịch bắt đầu trong quá khứ nghĩa là đang uống dở -> nạp cả liệu trình sẽ ra cữ cũ.
  const started = startDate < today;
%>
<main class="app-shell">
  <%- include('../partials/med-steps', { step: 4 }) %>
  <section class="feature-hero p mb">
    <div class="flex between center gap">
      <div>
        <h1>📅 Lịch uống thuốc</h1>
        <div class="muted strong-muted">
          <%= patient.name %>
          <% if (prescription.prescribedDate) { %> · đơn ngày <%= new Date(prescription.prescribedDate).toLocaleDateString('vi-VN') %><% } %>
        </div>
      </div>
    </div>
  </section>


  <%# Chốt lịch xong thì khoá luôn phần này: đổi ngày/giờ sau khi đã nạp vào iPhone sẽ
      sinh ra một mớ sự kiện lệch nhau mà không xoá được. %>
  <% if (!isConfirmed) { %>
    <section class="card-lite p mb">
      <div class="section-heading mb"><div><span class="feature-icon">⏱️</span><h2 class="section-title">Bắt đầu uống từ khi nào?</h2></div></div>
      <form method="post" action="/medical/prescriptions/<%= prescription.id %>/lich/tinh-lai">
        <div class="row">
          <div class="col-6"><label>Ngày bắt đầu</label><input type="date" name="start" value="<%= startDate %>"></div>
          <div class="col-6">
            <label>Cữ đầu tiên</label>
            <select name="slot">
              <% ['SANG', 'TRUA', 'TOI'].forEach((key) => { %>
                <option value="<%= key %>" <%= startSlot === key ? 'selected' : '' %>><%= slotLabels[key] %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <h3 class="mt">⏰ Giờ nhắc</h3>
        <div class="row">
          <div class="col-6"><label>Cữ sáng</label><input type="time" name="morning" value="<%= doseTimes.morning %>" required></div>
          <div class="col-6"><label>Cữ trưa</label><input type="time" name="noon" value="<%= doseTimes.noon %>" required></div>
          <div class="col-6"><label>Cữ tối</label><input type="time" name="evening" value="<%= doseTimes.evening %>" required></div>
          <div class="col-6"><label>Trước khi ngủ</label><input type="time" name="bedtime" value="<%= doseTimes.bedtime %>" required></div>
        </div>
        <p class="muted mt">Giờ nhắc áp dụng cho mọi đơn thuốc của <%= patient.name %>.</p>
        <div class="text-right mt"><button class="btn btn-primary" data-loading-text="Đang tính...">💾 Lưu giờ và tính lại</button></div>
      </form>
    </section>
  <% } %>

  <% if (overlaps.length) { %>
    <div class="alert-lite warn mb">
      <strong>⚠️ Người thân này còn đơn khác đang uống dở</strong>
      <ul>
        <% overlaps.forEach((o) => { %>
          <li>
            Đơn <%= o.date ? o.date.split('-').reverse().slice(0, 2).join('/') : 'không rõ ngày' %>:
            còn <strong><%= o.remainingCount %></strong> cữ đến hết <%= o.lastDate.split('-').reverse().slice(0, 2).join('/') %>
            (<%= o.drugs.join(', ') %>)
          </li>
        <% }) %>
      </ul>
      Nạp thêm lịch này thì trong Lịch iPhone sẽ có <strong>hai sự kiện chồng nhau cùng giờ</strong>, dễ cho uống nhầm gấp đôi.
      <%# Lời mời và nút phải đi CÙNG NHAU. Đơn đã dừng thì không được làm đích (bấm vào là
          giết đơn đang chạy) nên nút bị ẩn — để lại câu "bấm nút dưới" mà không có nút thì
          người dùng đi tìm mỏi mắt. %>
      <% if (canTransition) { %>
        <div class="mt">
          Bấm nút dưới để chọn <strong>thuốc nào của đơn cũ còn uống tiếp</strong>: thuốc được giữ sẽ chuyển sang đơn này
          (đã trừ phần đã uống), thuốc bỏ thì đơn cũ ngừng hẳn — sau đó chỉ còn <strong>một</strong> lịch phải nạp.
        </div>
        <div class="text-right mt">
          <a class="btn btn-primary" href="/medical/prescriptions/<%= prescription.id %>/chuyen-don">🔀 Chọn thuốc uống tiếp</a>
        </div>
      <% } else if (prescription.scheduleStopped) { %>
        <div class="mt">
          Đơn này <strong>đã dừng</strong> nên không nhận thêm thuốc được nữa. Muốn gom thuốc thì mở
          <strong>đơn mới nhất</strong> rồi làm ở đó.
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (duplicateDrugs.length) { %>
    <div class="alert-lite warn mb">
      <strong>⚠️ Thuốc bị kê TRÙNG trong cùng đơn này:</strong>
      <ul><% duplicateDrugs.forEach((name) => { %><li><%= name %></li><% }) %></ul>
      Lịch sẽ nhắc <strong>hai lần cùng một giờ</strong> cho mỗi thuốc trên, tức là uống gấp đôi liều.
      Thường gặp khi thuốc vừa được chuyển sang từ đơn cũ vừa được bác sĩ kê lại.
      Vào <a href="/medical/prescriptions/<%= prescription.id %>">trang đơn thuốc</a> bỏ tick một trong hai dòng rồi lưu lại.
    </div>
  <% } %>

  <% if (result.quantityMismatch.length) { %>
    <div class="alert-lite warn mb">
      <strong>⚠️ Số lượng cấp không đủ cho số ngày trong đơn:</strong>
      <ul>
        <% result.quantityMismatch.forEach((m) => { %>
          <li><%= m.drugName %> — lịch cần <strong><%= m.needed %> <%= m.unit %></strong> nhưng đơn chỉ cấp <strong><%= m.given %> <%= m.unit %></strong></li>
        <% }) %>
      </ul>
      Đối chiếu lại tờ đơn giấy: có thể AI đọc nhầm số ngày, hoặc nhà cần mua thêm.
    </div>
  <% } %>

  <% if (result.asNeeded.length) { %>
    <div class="alert-lite mb">
      <strong>🌡️ Thuốc dùng khi cần — cố ý KHÔNG đưa vào lịch nhắc:</strong>
      <ul>
        <% result.asNeeded.forEach((a) => { %>
          <li><%= a.drugName %><% if (a.dosage) { %> — <%= a.dosage %><% } %><% if (a.note) { %> (<%= a.note %>)<% } %></li>
        <% }) %>
      </ul>
      Loại này chỉ dùng khi có triệu chứng, nhắc đều đặn là sai. Nhớ là nhà có sẵn để lúc cần còn lấy.
    </div>
  <% } %>

  <% if (result.skipped.length) { %>
    <div class="alert-lite warn mb">
      <strong>⚠️ Chưa đưa vào lịch được <%= result.skipped.length %> thuốc:</strong>
      <ul>
        <% result.skipped.forEach((s) => { %><li><%= s.drugName %> — <%= s.reason %></li><% }) %>
      </ul>
      Quay lại <a href="/medical/patients/<%= patient.id %>">trang đơn thuốc</a> điền số lần/ngày và số ngày cho các thuốc này.
    </div>
  <% } %>

  <% if (!result.groups.length) { %>
    <section class="card-lite p mb"><p class="muted">Chưa có thuốc nào đủ thông tin để lên lịch.</p></section>
  <% } else { %>
    <section class="card-lite p mb">
      <div class="section-heading mb">
        <div><span class="feature-icon">📲</span><h2 class="section-title">Đặt vào Lịch iPhone</h2>
        <p class="muted"><%= result.groups.length %> cữ thuốc, từ <%= viDate(startDate) %> đến hết <%= viDate(result.lastDate) %>.</p></div>
      </div>

      <% if (!isConfirmed) { %>
        <form method="post" action="/medical/prescriptions/<%= prescription.id %>/lich/chot" class="mb">
          <input type="hidden" name="start" value="<%= startDate %>">
          <input type="hidden" name="slot" value="<%= startSlot %>">
          <p class="muted">Chốt lịch trước đã. Chốt xong thì ngày bắt đầu và giờ nhắc được khoá lại, tránh nạp vào iPhone rồi mới đổi.</p>
          <div class="text-right"><button class="btn btn-primary" data-loading-text="Đang chốt...">📌 Chốt lịch này</button></div>
        </form>
      <% } else { %>
        <div class="alert-lite mb">
          ✅ Lịch đã chốt từ <strong><%= viDate(confirmedStart) %></strong>.
        </div>
        <%# Nạp lại LUÔN là thêm mới, không bao giờ ghi đè — đã kiểm chứng trên cả iCloud
            lẫn Google (xem chú thích đầu ics.ts). Không sửa được từ server, nên việc duy
            nhất làm được là nói thẳng ra ở đúng chỗ người dùng sắp bấm. %>
        <div class="alert-lite warn mb">
          <strong>⚠️ Nạp lịch là THÊM MỚI, không ghi đè.</strong> Bấm hai lần là có hai bộ nhắc chồng nhau,
          và server không xoá hộ được — sự kiện đã vào máy thì chỉ xoá tay được thôi.
          <div class="mt">Nên làm theo đúng thứ tự này:</div>
          <ol>
            <li>Mở app Lịch, tạo một <strong>nhóm lịch mới</strong> (đặt tên theo ngày đơn cho dễ nhớ).</li>
            <li>Quay lại đây bấm nạp, chọn đúng <strong>nhóm vừa tạo</strong>.</li>
            <li>Xong xuôi thì <strong>xoá cả nhóm lịch cũ</strong> trong app Lịch.</li>
          </ol>
          Xoá cả nhóm chứ đừng xoá từng sự kiện — mỗi cữ là một sự kiện riêng, xoá tay từng cái là cả trăm lần bấm.
        </div>
      <% } %>

      <% if (started && isConfirmed && !remainingCount) { %>
        <div class="alert-lite mb">Không còn cữ nào cần nhắc — liệu trình đã xong.</div>
      <% } %>

      <div class="text-right mt">
        <% if (!isConfirmed) { %>
          <%# Chưa chốt thì khoá nút lại; server cũng chặn nên bấm tay vào link cũng không được. %>
          <button type="button" class="btn btn-success" data-blocked="Bạn phải bấm vào nút chốt lịch này trước">📥 Nạp lịch nhắc</button>
        <% } else if (remainingCount) { %>
          <%# data-no-busy: file .ics giao cho app Lịch, trang không điều hướng nên đừng bật spinner.
              data-ics-done: nạp xong (quay lại Safari) thì tự về trang đơn thuốc — xem script cuối trang. %>
          <a class="btn btn-success" data-no-busy data-ics-done="/medical/prescriptions/<%= prescription.id %>" href="<%= icsUrl %>">📥 Nạp <%= started ? remainingCount + ' cữ còn lại' : 'lịch nhắc' %></a>
          <% if (started) { %>
            <div class="mt"><a class="muted" data-no-busy data-ics-done="/medical/prescriptions/<%= prescription.id %>" href="<%= icsFullUrl %>">Nạp lại cả liệu trình từ đầu (gồm cữ đã qua)</a></div>
          <% } %>
          <div class="mt"><a class="muted" href="/medical/prescriptions/<%= prescription.id %>">← Về đơn thuốc</a></div>
        <% } %>
      </div>
    </section>

    <section class="card-lite p mb">
      <div class="section-heading mb"><div><span class="feature-icon">💊</span><h2 class="section-title">Từng thuốc uống thế nào</h2></div></div>
      <% if (carriedCount) { %>
        <p class="muted mb">
          <strong>🔄</strong> = thuốc uống tiếp từ đơn cũ, số ngày là phần <strong>còn lại</strong>.
          <strong>🆕</strong> = bác sĩ mới kê đợt này.
        </p>
      <% } %>
      <% byDrug.forEach((entry) => { const drugName = entry.line.drugName; %>
        <% const from = drugSources.get(entry.line.itemId); %>
        <div class="med-row">
          <strong><%= drugName %></strong>
          <% if (entry.line.isAntibiotic) { %> <span class="badge bg-danger">Kháng sinh</span><% } %>
          <%# Chỉ gắn nhãn khi đơn này thật sự có thuốc chuyển sang — đơn thuần một đợt thì
              dán 🆕 lên mọi dòng chỉ tổ nhiễu. %>
          <% if (from !== undefined) { %> <span class="badge">🔄 từ đơn <%= from || 'cũ' %></span>
          <% } else if (carriedCount) { %> <span class="badge bg-success">🆕 mới</span><% } %>
          <div class="muted med-row-detail">
            <%= [...entry.times].sort().join(' · ') %>
            <% if (entry.line.dosage) { %> — mỗi lần <%= entry.line.dosage %><% } %>
            <div><%= viDate(entry.first) %> → hết <%= viDate(entry.last) %> (<%= entry.doses %> lần)</div>
          </div>
        </div>
      <% }) %>
    </section>

    <details class="card-lite p mb">
      <summary><strong>🗓️ Xem trước chi tiết từng cữ (<%= result.groups.length %>)</strong></summary>
      <% byDate.forEach((groups, date) => { %>
        <div class="card-lite p mb">
          <strong><%= viDate(date) %></strong>
          <% groups.forEach((g) => { %>
            <div class="mt">
              <strong><%= g.time %></strong>
              <ul>
                <% g.lines.forEach((line) => { %>
                  <li>
                    <%= line.drugName %><% if (line.dosage) { %> — <%= line.dosage %><% } %>
                    <% if (line.isAntibiotic) { %> <span class="badge bg-danger">Kháng sinh</span><% } %>
                    <% if (drugSources.has(line.itemId)) { %> <span class="badge">🔄</span><% } %>
                  </li>
                <% }) %>
              </ul>
            </div>
          <% }) %>
        </div>
      <% }) %>
    </details>
  <% } %>
</main>
<script>
  // Nạp .ics xong thì đưa người dùng về trang đơn thuốc. iOS giao file cho app Lịch (Safari
  // bị che), nên CHỜ tới lúc họ quay lại trang (visible) rồi mới điều hướng — làm ngay lúc
  // bấm sẽ cắt ngang màn hình "Add All" của Lịch. Không quay lại thì thôi, không hại gì.
  (function () {
    var pending = null;
    document.addEventListener('click', function (e) {
      var a = e.target.closest ? e.target.closest('a[data-ics-done]') : null;
      if (a) pending = a.getAttribute('data-ics-done');
    });
    document.addEventListener('visibilitychange', function () {
      if (document.visibilityState === 'visible' && pending) {
        var url = pending;
        pending = null;
        location.href = url;
      }
    });
  })();
</script>
<%- include('../partials/bottom-menu') %>
