<%- include('../partials/head', { title: patient.name }) %>
<%- include('../partials/topbar') %>
<% const riskInfo = { LOW: { c: 'bg-success', t: '🟢 Ít rủi ro' }, MEDIUM: { c: 'bg-info text-dark', t: '🟠 Cần lưu ý' }, HIGH: { c: 'bg-danger', t: '🔴 Nguy cơ cao' } }; %>
<main class="app-shell">
  <section class="feature-hero p mb">
    <div class="flex between center gap">
      <div>
        <h1>🧑‍⚕️ <%= patient.name %></h1>
        <div class="muted strong-muted">
          <%= patient.birthYear ? (new Date().getFullYear() - patient.birthYear) + ' tuổi (' + patient.birthYear + ')' : 'Chưa rõ tuổi' %>
          <%= patient.gender ? ' · ' + patient.gender : '' %>
          <% if (patient.allergies) { %> · ⚠️ Dị ứng: <%= patient.allergies %><% } %>
          <% if (patient.conditions) { %> · Bệnh nền: <%= patient.conditions %><% } %>
        </div>
      </div>
    </div>
  </section>

  <% if (aiError) { %><div class="alert-lite warn mb">⚠️ <%= aiError %></div><% } %>
  <% if (!aiConfigured) { %><div class="alert-lite warn mb">Chưa cấu hình <code>GROQ_API_KEY</code> trên server nên chưa dùng được phân tích AI.</div><% } %>

  <section class="card-lite p mb">
    <div class="section-heading mb"><div><span class="feature-icon">📷</span><h2 class="section-title">Thêm đơn thuốc từ ảnh</h2><p class="muted">Chụp/chọn ảnh đơn thuốc, AI sẽ đọc thuốc và phân tích an toàn dựa trên các đơn cũ.</p></div></div>
    <form method="post" action="/medical/patients/<%= patient.id %>/prescriptions" data-medical-upload>
      <input type="hidden" name="imageData" data-image-data>
      <input type="hidden" name="imageMime" data-image-mime>
      <div class="row">
        <div class="col-6">
          <label>Ảnh đơn thuốc</label>
          <!-- Không đặt capture: iOS sẽ ép mở thẳng camera, không cho chọn ảnh có sẵn trong Thư viện. -->
          <input type="file" accept="image/*" data-image-file>
        </div>
        <div class="col-6"><img data-image-preview class="medical-preview hidden" alt="Xem trước"></div>
      </div>
      <div class="text-right mt"><button class="btn btn-success" data-image-submit disabled data-loading-text="AI đang đọc đơn..." <%= aiConfigured ? '' : 'disabled' %>>🤖 Đọc &amp; phân tích</button></div>
    </form>
  </section>

  <section class="card-lite p mb">
    <div class="section-heading mb"><div><span class="feature-icon">💊</span><h2 class="section-title">Lịch sử đơn thuốc</h2></div><span class="badge"><%= patient.prescriptions.length %></span></div>
    <% if (!patient.prescriptions.length) { %><p class="muted">Chưa có đơn thuốc nào.</p><% } %>
    <% patient.prescriptions.forEach((rx) => { %>
      <div class="card-lite p mb">
        <div class="flex between center gap mb">
          <div>
            <strong><%= rx.prescribedDate ? new Date(rx.prescribedDate).toLocaleDateString('vi-VN') : 'Không rõ ngày' %></strong>
            <% if (rx.doctor || rx.clinic) { %><span class="muted"> · <%= [rx.doctor, rx.clinic].filter(Boolean).join(' - ') %></span><% } %>
            <% if (rx.aiRisk && riskInfo[rx.aiRisk]) { %> <span class="badge <%= riskInfo[rx.aiRisk].c %>"><%= riskInfo[rx.aiRisk].t %></span><% } %>
          </div>
          <div class="flex gap">
            <% if (rx.imageData) { %><a class="btn btn-sm" href="/medical/prescriptions/<%= rx.id %>/image" target="_blank">🖼️ Ảnh</a><% } %>
            <form method="post" action="/medical/prescriptions/<%= rx.id %>/reanalyze"><button class="btn btn-sm" data-loading-text="..." <%= aiConfigured ? '' : 'disabled' %>>↻ Phân tích lại</button></form>
            <form method="post" action="/medical/prescriptions/<%= rx.id %>/delete" data-confirm="Xóa đơn thuốc này?"><button class="btn btn-sm btn-danger" data-loading-text="...">Xóa</button></form>
          </div>
        </div>
        <% if (rx.diagnosis) { %><p class="muted mb">Chẩn đoán: <%= rx.diagnosis %></p><% } %>
        <form method="post" action="/medical/prescriptions/<%= rx.id %>/items" data-med-items>
          <%
            /* Cố ý KHÔNG dùng <table>: 6 cột làm ô "Số ngày" rơi ra ngoài màn hình điện thoại,
               phải kéo ngang mới thấy — trong khi đó lại đúng là ô người dùng cần soát nhất. */
          %>
          <% rx.items.forEach((item) => { %>
            <div class="med-row <%= item.enabled ? '' : 'med-item-off' %>">
              <label class="med-row-use">
                <input type="checkbox" name="enabled_<%= item.id %>" <%= item.enabled ? 'checked' : '' %>>
                <span class="med-row-name">
                  <strong><%= item.drugName %></strong>
                  <% if (item.isAntibiotic) { %> <span class="badge bg-danger">Kháng sinh</span><% } %>
                </span>
              </label>
              <div class="muted med-row-detail">
                <%= [item.dosage, item.frequency, item.quantity].filter(Boolean).join(' · ') %>
                <% if (item.note) { %><div><%= item.note %></div><% } %>
              </div>
              <div class="med-row-nums">
                <label>Lần/ngày<input type="number" name="times_<%= item.id %>" value="<%= item.timesPerDay %>" min="0" max="6" class="med-num"></label>
                <%# step 0.5: đơn cấp theo số lượng hay ra số ngày lẻ (5 ống, ngày 2 lần = 2,5 ngày). %>
                <label>Số ngày<input type="number" name="days_<%= item.id %>" value="<%= item.days %>" min="0" max="90" step="0.5" class="med-num"></label>
              </div>
            </div>
          <% }) %>
          <p class="muted mt">Bỏ tick thuốc không dùng (bác sĩ gạch, hoặc nhà đã có). Số lần/ngày và số ngày do AI đọc từ ảnh — đối chiếu tờ đơn giấy rồi sửa nếu sai.</p>
          <%# Nút chỉ sáng khi có thay đổi thật (xem public/js/medical-upload.js). %>
          <div class="text-right mt"><button class="btn btn-primary" data-med-save disabled data-loading-text="Đang lưu...">💾 Lưu thay đổi</button></div>
        </form>
        <% if (rx.aiSummary) { %>
          <div class="medical-analysis mt"><strong>🤖 Phân tích AI:</strong><div class="medical-analysis-body"><%= rx.aiSummary %></div></div>
        <% } %>
      </div>
    <% }) %>
  </section>

  <% if (isOwner) { %>
    <details class="card-lite p mb">
      <summary><strong>🔐 Ai được xem hồ sơ này</strong></summary>
      <p class="muted mt">Mặc định chỉ mình bạn xem được. Cấp quyền để admin khác cùng theo dõi thuốc của bé.</p>
      <% if (patient.permissions.length) { %>
        <% patient.permissions.forEach((perm) => { %>
          <div class="flex between center gap med-row">
            <span><%= perm.admin.displayName || perm.admin.username %></span>
            <form method="post" action="/medical/patients/<%= patient.id %>/permissions/<%= perm.id %>/delete" data-confirm="Thu quyền xem hồ sơ của người này?">
              <button class="btn btn-sm btn-danger" data-loading-text="...">Thu quyền</button>
            </form>
          </div>
        <% }) %>
      <% } else { %>
        <p class="muted">Chưa cấp cho ai.</p>
      <% } %>
      <% if (availableAdmins.length) { %>
        <form method="post" action="/medical/patients/<%= patient.id %>/permissions" class="mt">
          <label>Cho admin khác xem cùng</label>
          <div class="flex gap center">
            <select name="adminId" required>
              <option value="">-- Chọn admin --</option>
              <% availableAdmins.forEach((admin) => { %>
                <option value="<%= admin.id %>"><%= admin.displayName || admin.username %></option>
              <% }) %>
            </select>
            <button class="btn btn-primary" data-loading-text="...">Cấp quyền</button>
          </div>
        </form>
      <% } %>
    </details>
  <% } %>

  <details class="card-lite p mb">
    <summary><strong>✏️ Sửa thông tin / xóa người thân</strong></summary>
    <form class="medical-form mt" method="post" action="/medical/patients/<%= patient.id %>/edit">
      <div><label>Họ tên</label><input name="name" value="<%= patient.name %>" required></div>
      <div><label>Năm sinh</label><input name="birthYear" type="number" value="<%= patient.birthYear || '' %>"></div>
      <div><label>Giới tính</label><select name="gender"><option value="">--</option><option value="Nam" <%= patient.gender==='Nam'?'selected':'' %>>Nam</option><option value="Nữ" <%= patient.gender==='Nữ'?'selected':'' %>>Nữ</option></select></div>
      <div><label>Dị ứng</label><input name="allergies" value="<%= patient.allergies || '' %>"></div>
      <div class="medical-form-wide"><label>Bệnh nền</label><input name="conditions" value="<%= patient.conditions || '' %>"></div>
      <div class="medical-form-wide"><label>Ghi chú</label><input name="notes" value="<%= patient.notes || '' %>"></div>
      <div class="medical-form-actions"><button class="btn btn-primary" data-loading-text="Đang lưu...">Lưu thay đổi</button></div>
    </form>
    <form method="post" action="/medical/patients/<%= patient.id %>/delete" data-confirm="Xóa người thân này và toàn bộ đơn thuốc?" class="mt"><button class="btn btn-danger btn-sm">Xóa người thân</button></form>
  </details>
</main>
<script src="/js/medical-upload.js"></script>
<%- include('../partials/bottom-menu') %>
