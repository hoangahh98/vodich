<%- include('../partials/head', { title: 'Y tế' }) %>
<%- include('../partials/topbar') %>
<main class="app-shell">
  <section class="feature-hero p mb">
    <div class="flex between center gap">
      <div><h1>🩺 Sổ y tế gia đình</h1><div class="muted strong-muted">Lưu hồ sơ người thân và phân tích đơn thuốc bằng AI (chỉ tham khảo).</div></div>
      <div class="feature-hero-art">🩺</div>
    </div>
  </section>

  <section class="card-lite p mb">
    <div class="section-heading mb"><div><span class="feature-icon">➕</span><h2 class="section-title">Thêm người thân</h2></div></div>
    <form class="medical-form" method="post" action="/medical/patients">
      <div><label>Họ tên</label><input name="name" required placeholder="VD: Bé An"></div>
      <div><label>Năm sinh</label><input name="birthYear" type="number" min="1900" max="2200" placeholder="VD 2018"></div>
      <div><label>Giới tính</label><select name="gender"><option value="">--</option><option value="Nam">Nam</option><option value="Nữ">Nữ</option></select></div>
      <div><label>Dị ứng</label><input name="allergies" placeholder="VD: penicillin"></div>
      <div class="medical-form-wide"><label>Bệnh nền</label><input name="conditions" placeholder="VD: hen suyễn"></div>
      <div class="medical-form-wide"><label>Ghi chú</label><input name="notes"></div>
      <div class="medical-form-actions"><button class="btn btn-success" data-loading-text="Đang lưu...">Thêm người thân</button></div>
    </form>
  </section>

  <section class="card-lite p">
    <div class="section-heading mb"><div><span class="feature-icon">👨‍👩‍👧</span><h2 class="section-title">Người thân</h2></div><span class="badge"><%= patients.length %></span></div>
    <div class="grid module-grid">
      <% patients.forEach((patient, i) => { %>
        <%
          const active = activeSchedules[i];
          const [ly, lm, ld] = active ? active.lastDate.split('-') : [];
        %>
        <%# Không bọc cả thẻ trong <a> nữa vì bên trong có nút nạp lịch — lồng <a> trong <a> là HTML sai. %>
        <div class="card-lite module-card">
          <a class="module-card-main" href="/medical/patients/<%= patient.id %>">
            <div class="module-icon">🧑‍⚕️</div>
            <h3><%= patient.name %></h3>
            <p class="muted"><%= patient.birthYear ? (new Date().getFullYear() - patient.birthYear) + ' tuổi' : 'Chưa rõ tuổi' %> · <%= patient._count.prescriptions %> đơn thuốc</p>
          </a>
          <% if (active) { %>
            <p class="muted">💊 Còn <strong><%= active.remainingCount %></strong> cữ, đến hết <%= ld %>/<%= lm %></p>
            <%# data-no-busy: file .ics giao cho app Lịch, trang không điều hướng nên đừng bật spinner. %>
            <a class="btn btn-sm btn-success" data-no-busy href="/medical/prescriptions/<%= active.prescriptionId %>/lich.ics">📥 Nạp lịch nhắc</a>
          <% } %>
        </div>
      <% }) %>
      <% if (!patients.length) { %><p class="muted">Chưa có người thân nào. Thêm ở trên nhé.</p><% } %>
    </div>
  </section>
</main>
<%- include('../partials/bottom-menu') %>
