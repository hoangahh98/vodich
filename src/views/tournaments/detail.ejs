<%- include('../partials/head', { title: tournament.name }) %>
<%- include('../partials/topbar') %>
<% const paymentLabels = { PAID: 'Đã đóng', UNPAID: 'Chưa đóng' }; %>
<% const slotsLeft = Math.max(0, tournament.expectedPlayers - registrations.length); %>
<% const totalCost = Number(tournament.courtCost) + Number(tournament.foodCost) + Number(tournament.prizeCost) + Number(tournament.otherCost); %>
<% const totalPaid = registrations.reduce((sum, r) => sum + Number(r.paidAmount || 0), 0); %>
<% const totalExpected = registrations.length * minimumFee; %>
<% const unpaidCount = registrations.filter((r) => r.paymentStatus !== 'PAID').length; %>
<% const missingFee = unpaidCount * minimumFee; %>
<% const operatingCost = Number(tournament.courtCost) + Number(tournament.foodCost) + Number(tournament.otherCost); %>
<% const prizeFund = Math.max(0, totalPaid - operatingCost); %>
<% const manualPrize = Number(tournament.prizeRate1) > 100 || Number(tournament.prizeRate2) > 100 || Number(tournament.prizeRate3) > 100; %>
<% const prizeRateTotal = Number(tournament.prizeRate1) + Number(tournament.prizeRate2) + Number(tournament.prizeRate3) || 100; %>
<% const prize1 = manualPrize ? Number(tournament.prizeRate1) : prizeFund * Number(tournament.prizeRate1) / prizeRateTotal; %>
<% const prize2 = manualPrize ? Number(tournament.prizeRate2) : prizeFund * Number(tournament.prizeRate2) / prizeRateTotal; %>
<% const prize3 = manualPrize ? Number(tournament.prizeRate3) : prizeFund * Number(tournament.prizeRate3) / prizeRateTotal; %>
<% const topDonors = registrations.map((r) => ({ name: r.player ? r.player.displayName : r.externalName, amount: Math.max(0, Number(r.paidAmount || 0) - minimumFee) })).filter((item) => item.amount > 0).sort((a, b) => b.amount - a.amount).slice(0, 3); %>
<% const currentEmail = String(currentUser?.email || currentUser?.username || '').toLowerCase(); %>
<% const myNames = new Set([...registrations, ...(reserveRegistrations || []), ...withdrawnRegistrations].filter((r) => String(r.player ? r.player.email : r.externalEmail || '').toLowerCase() === currentEmail).map((r) => r.player ? r.player.displayName : r.externalName).filter(Boolean)); %>
<% const isMine = (name) => [...myNames].some((myName) => String(name || '').includes(myName)); %>
<main class="app-shell" data-tournament-id="<%= tournament.id %>">
  <section class="feature-hero p mb">
    <div class="flex between center">
      <div>
        <h1><%= tournament.name %></h1>
        <div class="muted strong-muted">📍 <%= tournament.venue || 'Chưa có địa điểm' %> · Lệ phí <%= formatMoney(minimumFee) %>đ/người · <%= tournament.format === 'GROUP_KNOCKOUT' ? 'Vòng bảng + loại trực tiếp' : 'Vòng tròn' %></div>
      </div>
      <div class="hero-actions">
        <% if (currentUser.role === 'ADMIN') { %>
          <div class="hero-action-buttons">
            <button class="btn btn-sm btn-primary" type="button" data-open-modal="emailModal">Get Email</button>
            <button class="btn btn-sm btn-success" type="button" data-open-modal="contentModal">Content mẫu</button>
          </div>
        <% } %>
        <div class="feature-hero-art">🏆</div>
      </div>
    </div>
    <% if (currentUser.role === 'ADMIN') { %>
      <textarea id="emailListText" class="hidden"><%= [...registrations, ...(reserveRegistrations || [])].map((r) => r.player ? r.player.email : r.externalEmail).filter(Boolean).join('; ') %></textarea>
    <% } %>
  </section>
  <% if (currentUser.role === 'ADMIN') { %>
    <div id="emailModal" class="score-modal hidden" aria-hidden="true">
      <div class="score-modal-backdrop" data-close-modal="emailModal"></div>
      <div class="score-modal-panel" role="dialog" aria-modal="true">
        <div class="score-modal-head"><div><h3>Danh sách email</h3><small>Copy email thành viên trong giải</small></div><button class="btn btn-sm" type="button" data-close-modal="emailModal">Đóng</button></div>
        <div class="score-modal-body">
          <textarea id="emailModalText" rows="8"><%= [...registrations, ...(reserveRegistrations || [])].map((r) => r.player ? r.player.email : r.externalEmail).filter(Boolean).join('; ') %></textarea>
          <div class="mt text-right"><button class="btn btn-primary" type="button" data-copy-target="emailModalText">Copy email</button></div>
        </div>
      </div>
    </div>
    <div id="contentModal" class="score-modal hidden" aria-hidden="true">
      <div class="score-modal-backdrop" data-close-modal="contentModal"></div>
      <div class="score-modal-panel" role="dialog" aria-modal="true">
        <div class="score-modal-head"><div><h3>Content mẫu</h3><small>Copy gửi cho thành viên</small></div><button class="btn btn-sm" type="button" data-close-modal="contentModal">Đóng</button></div>
        <div class="score-modal-body">
          <textarea id="contentSampleText" rows="10">Xin chào Anh/Chị,

Chào mừng Anh/Chị đến với giải đấu "<%= tournament.name %>" tại <%= tournament.venue || 'địa điểm sẽ được cập nhật' %>.

Link xem thông tin giải:
<%= tournamentLink %>

BTC rất mong Anh/Chị có mặt đúng giờ để giải đấu diễn ra thuận lợi.</textarea>
          <div class="mt text-right"><button class="btn btn-primary" type="button" data-copy-target="contentSampleText">Copy nội dung</button></div>
        </div>
      </div>
    </div>
  <% } %>

  <% if (section === 'players') { %>
    <section class="card-lite p">
      <div class="section-heading mb"><div><span class="feature-icon">👥</span><h2 class="section-title">Thành viên</h2><p class="muted">Quản lý chính thức, dự bị và thao tác nhiều người một lúc.</p></div><span class="badge"><%= registrations.length %>/<%= tournament.expectedPlayers %></span></div>
      <% if (currentUser.role === 'ADMIN' && tournament.externalRegistrationEnabled) { %><div class="card-lite p mb"><strong>Link đăng ký ngoài</strong><input value="<%= externalLink %>" readonly></div><% } %>
      <% if (currentUser.role === 'ADMIN') { %>
        <form id="addTournamentPlayersForm" class="mb" method="post" action="/tournaments/<%= tournament.id %>/registrations">
          <% const usedPlayerIds = new Set([...registrations, ...(reserveRegistrations || []), ...withdrawnRegistrations].map((r) => r.playerId && r.playerId.toString()).filter(Boolean)); %>
          <div id="playerSlotHint" class="alert-lite <%= slotsLeft > 0 ? 'info' : 'warn' %> mb" data-slots-left="<%= slotsLeft %>">Còn <strong data-slot-count><%= slotsLeft %></strong> suất chính thức. Đã chọn <strong data-selected-count>0</strong> thành viên.</div>
          <div class="player-check-list mb" data-player-picker>
            <% players.filter((p) => !usedPlayerIds.has(p.id.toString())).forEach((p) => { %>
              <label><input type="checkbox" name="playerId" value="<%= p.id %>"><span><strong><%= p.displayName %></strong><small><%= p.email %> · <%= p.skillLevel || 'Chưa chọn trình' %></small></span></label>
            <% }) %>
          </div>
          <button class="btn btn-success" data-loading-text="Đang thêm...">Thêm thành viên đã chọn</button>
        </form>
      <% } %>
      <form class="registration-panel" method="post" action="/tournaments/<%= tournament.id %>/registrations/bulk" <%= currentUser.role === 'ADMIN' ? 'data-require-checked="registrationIds" data-confirm="Xử lý các thành viên đã chọn?"' : '' %>>
        <div class="bulk-toolbar mb"><strong>Chính thức</strong><span class="muted"><%= registrations.length %> thành viên</span><% if (currentUser.role === 'ADMIN') { %><div class="flex gap"><button class="btn btn-sm" name="bulkAction" value="withdraw" data-loading-text="Đang bỏ giải...">Bỏ giải đã chọn</button><button class="btn btn-sm btn-danger" name="bulkAction" value="delete" data-loading-text="Đang xóa...">Xóa đã chọn</button></div><% } %></div>
        <div class="table-wrap"><table><thead><tr><% if (currentUser.role === 'ADMIN') { %><th class="check-col"><input type="checkbox" data-check-all="[data-active-registration]"></th><% } %><th>Tên</th><th>Trình</th></tr></thead><tbody>
          <% registrations.forEach((r) => { const mine = String(r.player ? r.player.email : r.externalEmail || '').toLowerCase() === currentEmail; %><tr class="<%= mine ? 'mine-row' : '' %>"><% if (currentUser.role === 'ADMIN') { %><td><input data-active-registration type="checkbox" name="registrationIds" value="<%= r.id %>"></td><% } %><td><strong><%= r.player ? r.player.displayName : r.externalName %></strong><br><span class="muted"><%= r.player ? r.player.email : r.externalEmail || '-' %></span><br><span class="muted"><%= r.source === 'EXTERNAL' ? 'Đăng ký ngoài' : 'Danh sách chung' %></span></td><td><% if (currentUser.role === 'ADMIN' && r.source === 'EXTERNAL') { %><input type="hidden" name="tournamentId" value="<%= tournament.id %>" form="skill-<%= r.id %>"><select name="skillLevel" form="skill-<%= r.id %>" onchange="document.getElementById('skill-<%= r.id %>').submit()"><option value="" <%= !r.skillLevel ? 'selected' : '' %>>Chưa chọn</option><% ['A','B','C','D'].forEach((level) => { %><option value="<%= level %>" <%= r.skillLevel === level ? 'selected' : '' %>><%= level %></option><% }) %></select><% } else { %><span class="badge"><%= r.skillLevel || '-' %></span><% } %></td></tr><% }) %>
          <% if (!registrations.length) { %><tr><td colspan="<%= currentUser.role === 'ADMIN' ? 3 : 2 %>" class="muted text-center">Chưa có thành viên chính thức.</td></tr><% } %>
        </tbody></table></div>
      </form>
      <% if (reserveRegistrations && reserveRegistrations.length) { %>
        <form class="registration-panel mt" method="post" action="/tournaments/<%= tournament.id %>/registrations/bulk" <%= currentUser.role === 'ADMIN' ? 'data-require-checked="registrationIds" data-confirm="Xử lý các thành viên dự bị đã chọn?"' : '' %>>
          <div class="bulk-toolbar mb"><strong>Dự bị</strong><span class="muted"><%= reserveRegistrations.length %> thành viên</span><% if (currentUser.role === 'ADMIN') { %><div class="flex gap"><button class="btn btn-sm" name="bulkAction" value="restore" <%= slotsLeft <= 0 ? 'disabled title="Đã đủ thành viên chính thức"' : '' %> data-loading-text="Đang đưa vào giải...">Đưa vào giải</button><button class="btn btn-sm" name="bulkAction" value="withdraw" data-loading-text="Đang bỏ giải...">Bỏ giải đã chọn</button><button class="btn btn-sm btn-danger" name="bulkAction" value="delete" data-loading-text="Đang xóa...">Xóa đã chọn</button></div><% } %></div>
          <div class="table-wrap"><table><thead><tr><% if (currentUser.role === 'ADMIN') { %><th class="check-col"><input type="checkbox" data-check-all="[data-reserve-registration]"></th><% } %><th>Tên</th><th>Trình</th></tr></thead><tbody>
            <% reserveRegistrations.forEach((r) => { const mine = String(r.player ? r.player.email : r.externalEmail || '').toLowerCase() === currentEmail; %><tr class="insufficient-row <%= mine ? 'mine-row' : '' %>"><% if (currentUser.role === 'ADMIN') { %><td><input data-reserve-registration type="checkbox" name="registrationIds" value="<%= r.id %>"></td><% } %><td><strong><%= r.player ? r.player.displayName : r.externalName %></strong><br><span class="muted"><%= r.player ? r.player.email : r.externalEmail || '-' %></span><br><span class="muted"><%= r.source === 'EXTERNAL' ? 'Đăng ký ngoài' : 'Danh sách chung' %></span></td><td><% if (currentUser.role === 'ADMIN' && r.source === 'EXTERNAL') { %><input type="hidden" name="tournamentId" value="<%= tournament.id %>" form="skill-<%= r.id %>"><select name="skillLevel" form="skill-<%= r.id %>" onchange="document.getElementById('skill-<%= r.id %>').submit()"><option value="" <%= !r.skillLevel ? 'selected' : '' %>>Chưa chọn</option><% ['A','B','C','D'].forEach((level) => { %><option value="<%= level %>" <%= r.skillLevel === level ? 'selected' : '' %>><%= level %></option><% }) %></select><% } else { %><span class="badge"><%= r.skillLevel || '-' %></span><% } %></td></tr><% }) %>
          </tbody></table></div>
        </form>
      <% } %>
      <% if (withdrawnRegistrations.length) { %><div class="registration-panel mt"><div class="bulk-toolbar mb"><strong>Bỏ giải</strong><span class="muted"><%= withdrawnRegistrations.length %> thành viên</span></div><% withdrawnRegistrations.forEach((r) => { %><div class="flex between center card-lite p mb"><span><%= r.player ? r.player.displayName : r.externalName %></span><form method="post" action="/registrations/<%= r.id %>/restore"><input type="hidden" name="tournamentId" value="<%= tournament.id %>"><button class="btn btn-sm" data-loading-text="Đang khôi phục...">Khôi phục</button></form></div><% }) %></div><% } %>
      <% if (currentUser.role === 'ADMIN') { [...registrations, ...(reserveRegistrations || [])].filter((r) => r.source === 'EXTERNAL').forEach((r) => { %><form id="skill-<%= r.id %>" method="post" action="/registrations/<%= r.id %>/skill"></form><% }) } %>
    </section>
  <% } %>

  <% if (section === 'fund') { %>
    <section class="card-lite p">
      <div class="section-heading mb"><div><span class="feature-icon">🏆</span><h2 class="section-title">Quỹ giải thưởng</h2><p class="muted">Tổng hợp chi phí, tiền đã thu và quỹ thưởng thực tế.</p></div></div>
      <div class="grid finance-grid mb">
        <div class="metric-card blue"><span>💰 Tổng thu</span><strong><%= formatMoney(totalPaid) %>đ</strong><small><%= registrations.length %> thành viên chính thức</small></div>
        <div class="metric-card green"><span>✅ Lệ phí/người</span><strong><%= formatMoney(minimumFee) %>đ</strong><small>Dựa trên <%= formatMoney(totalCost) %>đ chi phí</small></div>
        <div class="metric-card orange"><span>⚠️ Còn thiếu</span><strong><%= formatMoney(missingFee) %>đ</strong><small><%= unpaidCount %> người đang ở trạng thái ✕</small></div>
        <div class="metric-card gold"><span>🏆 Quỹ thưởng</span><strong><%= formatMoney(prizeFund) %>đ</strong><small>Đã thu - sân/ăn/khác</small></div>
      </div>
      <div class="grid team-admin-grid">
        <div class="card-lite">
          <div class="card-hdr warn">🏆 Cơ cấu giải thưởng</div>
          <div class="p">
            <div class="prize-row"><span>🥇 Nhất</span><strong><%= formatMoney(prize1) %>đ</strong></div>
            <div class="prize-row"><span>🥈 Nhì</span><strong><%= formatMoney(prize2) %>đ</strong></div>
            <div class="prize-row"><span>🥉 Ba</span><strong><%= formatMoney(prize3) %>đ</strong></div>
            <p class="muted mt"><%= manualPrize ? 'Đang đặt thưởng thủ công' : `Tỷ lệ hiện tại: ${formatMoney(tournament.prizeRate1)}% / ${formatMoney(tournament.prizeRate2)}% / ${formatMoney(tournament.prizeRate3)}%` %></p>
          </div>
        </div>
        <div class="card-lite">
          <div class="card-hdr green">👑 Top đóng góp</div>
          <div class="p">
            <% if (topDonors.length) { topDonors.forEach((donor, index) => { %>
              <div class="prize-row"><span><%= ['🥇','🥈','🥉'][index] %> <%= donor.name %></span><strong>+<%= formatMoney(donor.amount) %>đ</strong></div>
            <% }) } else { %>
              <p class="muted text-center">Chưa có ai đóng vượt mức lệ phí.</p>
            <% } %>
          </div>
        </div>
      </div>
      <div class="grid module-grid mt">
        <div class="cost-card">🏟️<span>Sân bãi</span><strong><%= formatMoney(tournament.courtCost) %>đ</strong></div>
        <div class="cost-card">🥤<span>Ăn uống</span><strong><%= formatMoney(tournament.foodCost) %>đ</strong></div>
        <div class="cost-card">🎁<span>Ngân sách thưởng gốc</span><strong><%= formatMoney(tournament.prizeCost) %>đ</strong></div>
        <div class="cost-card">🧾<span>Khác</span><strong><%= formatMoney(tournament.otherCost) %>đ</strong></div>
      </div>
    </section>
  <% } %>

  <% if (section === 'ranking') { %>
    <section class="card-lite p ranking-live"><div class="section-heading mb"><div><span class="feature-icon">📊</span><h2 class="section-title">Bảng xếp hạng</h2><p class="muted">Theo dõi số trận, điểm và hiệu số sau mỗi trận.</p></div></div>
      <% if (!rankingGroups.length) { %><p class="muted">Chưa có trận thi đấu để tính xếp hạng.</p><% } %>
      <div class="ranking-board-list">
        <% rankingGroups.forEach((group) => { %>
          <div class="ranking-board">
            <div class="ranking-board-title"><span>🏅</span><strong><%= tournament.format === 'ROUND_ROBIN' ? 'Bảng xếp hạng' : `Bảng xếp hạng ${group.groupName}` %></strong></div>
            <div class="table-wrap ranking-table"><table><thead><tr><th>#</th><th>Đội</th><th>Trận</th><th class="text-success">W</th><th class="text-danger">L</th><th>Điểm</th><th>Hiệu số</th></tr></thead><tbody>
              <% group.rows.forEach((row, index) => { const rank = index + 1; const rankLabel = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : rank; const rankClass = rank === 1 ? 'rank-1' : rank === 2 ? 'rank-2' : rank === 3 ? 'rank-3' : ''; %><tr class="<%= rankClass %> <%= isMine(row.teamName) ? 'mine-row' : '' %>"><td><%= rankLabel %></td><td><strong class="ranking-team-name"><% String(row.teamName).split(/\s*\/\s*/).forEach((name) => { %><span><%= name %></span><% }) %></strong></td><td><%= row.played %></td><td class="text-success"><strong><%= row.won %></strong></td><td class="text-danger"><%= row.lost %></td><td><span class="badge bg-primary rounded-pill"><%= row.rankingPoints %></span></td><td class="<%= row.pointDiff > 0 ? 'hieu-so-pos' : row.pointDiff < 0 ? 'hieu-so-neg' : '' %>"><%= row.pointDiff > 0 ? '+' : '' %><%= row.pointDiff %></td></tr><% }) %>
            </tbody></table></div>
          </div>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (section === 'schedule') { %>
    <section class="card-lite p">
      <div class="section-heading mb"><div><span class="feature-icon">🗓️</span><h2 class="section-title">Thi đấu</h2><p class="muted"><% if (tournament.format === 'GROUP_KNOCKOUT') { %>Vào vòng trong: <%= tournament.knockoutQualifierCount %> đội<% } else { %>Bấm vào thẻ trận để mở màn ghi điểm.<% } %></p></div><% if (currentUser.role === 'ADMIN') { %><form method="post" action="/tournaments/<%= tournament.id %>/generate-schedule"><button class="btn btn-primary" data-loading-text="Đang chia...">Chia trận</button></form><% } %></div>
      <% if (currentUser.role === 'ADMIN' && tournament.playType === 'DOUBLES' && registrations.length >= 2) { %>
        <details class="manual-pair-box mb">
          <summary>Ghép đội thủ công</summary>
          <form method="post" action="/tournaments/<%= tournament.id %>/manual-schedule" data-confirm="Ghép đội thủ công sẽ xóa các trận và tỷ số hiện tại. Tiếp tục?">
            <% const pairCount = Math.floor(registrations.length / 2); %>
            <input type="hidden" name="pairCount" value="<%= pairCount %>">
            <div class="grid manual-pair-grid">
              <% for (let i = 1; i <= pairCount; i++) { %>
                <div class="manual-pair-card">
                  <strong>Đội <%= i %></strong>
                  <div class="row">
                    <div class="col-6"><select class="manual-pair-select" name="teamA_<%= i %>" data-manual-pair-select><option value="">Thành viên 1</option><% registrations.forEach((r) => { const name = r.player ? r.player.displayName : r.externalName; %><option value="<%= name %>"><%= name %></option><% }) %></select></div>
                    <div class="col-6"><select class="manual-pair-select" name="teamB_<%= i %>" data-manual-pair-select><option value="">Thành viên 2</option><% registrations.forEach((r) => { const name = r.player ? r.player.displayName : r.externalName; %><option value="<%= name %>"><%= name %></option><% }) %></select></div>
                  </div>
                </div>
              <% } %>
            </div>
            <div class="mt"><button class="btn btn-primary" data-loading-text="Đang tạo...">Tạo trận từ đội đã ghép</button></div>
          </form>
        </details>
      <% } %>
      <div id="matchList" data-tournament-id="<%= tournament.id %>" data-touch-score="<%= tournament.touchScore || 11 %>" data-max-score="<%= tournament.maxScore || 15 %>" data-knockout-touch-score="<%= tournament.knockoutTouchScore || 15 %>" data-knockout-max-score="<%= tournament.knockoutMaxScore || 19 %>">
        <%
          const roundMap = new Map();
          matches.forEach((match) => {
            const list = roundMap.get(match.roundNumber) || [];
            list.push(match);
            roundMap.set(match.roundNumber, list);
          });
          const roundTitle = (round, list) => {
            const stage = list.find((item) => item.stage !== 'Vòng bảng' && item.stage !== 'Vòng tròn')?.stage;
            if (stage) return `🏆 ${stage.toUpperCase()}`;
            if (round === 100) return '🏆 TỨ KẾT';
            if (round === 101) return '🏆 BÁN KẾT';
            if (round === 102) return '🏆 CHUNG KẾT';
            return tournament.format === 'GROUP_KNOCKOUT' ? `🔄 LƯỢT ${round}` : `🔄 VÒNG ${round}`;
          };
        %>
        <% if (!matches.length) { %>
          <div class="text-center py-4">
            <p class="muted mb">Chưa có trận thi đấu. Bấm bên trên để tự động chia trận.</p>
            <% if (currentUser.role === 'ADMIN') { %>
              <form method="post" action="/tournaments/<%= tournament.id %>/generate-schedule"><button class="btn btn-primary" data-loading-text="Đang chia...">⚡ TỰ ĐỘNG CHIA TRẬN</button></form>
            <% } %>
          </div>
        <% } %>
        <% if (tournament.format === 'GROUP_KNOCKOUT' && groupBoards && groupBoards.length) { %>
          <div class="mb-4">
            <div class="vong-header rounded px-3 py-2 mb-3 fw-bold text-success">📋 DANH SÁCH BẢNG ĐẤU</div>
            <div class="grid group-grid">
              <% groupBoards.forEach((group) => { %>
                <div class="group-board">
                  <div class="group-board-title">Bảng <%= group.groupName %></div>
                  <% group.teams.forEach((team) => { %>
                    <div class="group-team-row <%= isMine(team) ? 'mine-row' : '' %>"><strong class="team-name"><% String(team).split(/\s*\/\s*/).forEach((name) => { %><span><%= name %></span><% }) %></strong></div>
                  <% }) %>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
        <% Array.from(roundMap.entries()).forEach(([round, roundMatches]) => { 
          const doneCount = roundMatches.filter((item) => item.status === 'FINISHED').length;
          const courtMap = new Map();
          roundMatches.forEach((match) => {
            const list = courtMap.get(match.courtNumber) || [];
            list.push(match);
            courtMap.set(match.courtNumber, list);
          });
          const courts = Array.from(courtMap.entries());
        %>
          <div class="mb-4" data-round-block>
            <div class="vong-header rounded px-3 py-2 mb-3 fw-bold text-primary">
              <%= roundTitle(round, roundMatches) %> — <%= roundMatches.length %> trận
              <small class="text-muted fw-normal ms-2">(<span data-done-count><%= doneCount %></span> đã xong)</small>
            </div>
            <div class="grid courts-grid">
              <% courts.forEach(([court, courtMatches]) => { %>
                <div class="court-column">
                  <div class="border rounded p-2 h-100" style="border-color:#0d6efd44!important;">
                    <div class="text-center fw-bold small text-primary mb-2">🏟️ SÂN <%= court %></div>
                    <% courtMatches.forEach((m) => { const knockout = m.stage !== 'Vòng bảng' && m.stage !== 'Vòng tròn'; const done = m.status === 'FINISHED'; %>
                      <div class="tran-card rounded p-2 mb-2 <%= done ? 'da-xong' : '' %> <%= knockout ? 'knockout' : '' %> <%= isMine(m.teamA) || isMine(m.teamB) ? 'mine-card' : '' %>" tabindex="0" data-match-id="<%= m.id %>" data-team-a="<%= m.teamA %>" data-team-b="<%= m.teamB %>" data-score-a="<%= m.scoreA %>" data-score-b="<%= m.scoreB %>" data-score-order="<%= m.scoreOrder || 2 %>" data-serving-team="<%= m.servingTeam || 'A' %>" data-knockout="<%= knockout ? 'true' : 'false' %>">
                        <div class="match-meta">
                          <% if (m.stage === 'Vòng bảng') { %>
                            <span class="badge bg-success">Lượt <%= round %></span>
                            <span class="badge bg-info text-dark">Bảng <%= m.groupName || 'A' %></span>
                          <% } else if (knockout) { %>
                            <span class="badge bg-danger"><%= m.stage %></span>
                          <% } else { %>
                            <span class="badge bg-primary">Vòng <%= round %></span>
                          <% } %>
                          <span class="badge bg-secondary">Sân <%= court %></span>
                        </div>
                        <div class="match-grid">
                          <div class="team-name">
                            <% String(m.teamA).split(/\s*\/\s*/).forEach((name) => { %><span><%= name %></span><% }) %>
                          </div>
                          <div class="score-section">
                            <span class="badge <%= done ? 'bg-success' : 'bg-primary' %> px-2 py-1 score-pill">
                              <span class="score-a"><%= m.scoreA %></span> – <span class="score-b"><%= m.scoreB %></span> - <span class="score-order"><%= m.scoreOrder || 2 %></span>
                            </span>
                            <span class="badge <%= done ? 'bg-success' : 'bg-secondary' %> match-status"><%= done ? 'Đã xong' : 'Đang đánh' %></span>
                            <% if (currentUser.role === 'ADMIN') { %><small class="muted">Bấm thẻ để ghi điểm</small><% } %>
                          </div>
                          <div class="team-name text-end">
                            <% String(m.teamB).split(/\s*\/\s*/).forEach((name) => { %><span><%= name %></span><% }) %>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
    <% if (currentUser.role === 'ADMIN') { %>
      <div id="scoreModal" class="score-modal hidden" aria-hidden="true">
        <div class="score-modal-backdrop" data-score-close></div>
        <div class="score-modal-panel" role="dialog" aria-modal="true">
          <div class="score-modal-head">
            <div><h3>Ghi điểm trận đấu</h3><small>Tự lưu khi thay đổi điểm</small></div>
            <button type="button" class="btn btn-sm" data-score-close data-loading-text="Đang đóng...">Đóng</button>
          </div>
          <div class="score-modal-body">
            <div class="score-sides">
              <div class="score-side" id="scoreSideA" data-serving-side="A">
                <strong id="scoreTeamA"></strong>
                <div class="score-step-row">
                  <button type="button" class="btn score-step-btn" data-score-target="A" data-score-delta="-1">-</button>
                  <div id="scoreInputA" class="live-score-number">0</div>
                  <button type="button" class="btn btn-primary score-step-btn" data-score-target="A" data-score-delta="1">+</button>
                </div>
              </div>
              <div class="score-divider">-</div>
              <div class="score-side" id="scoreSideB" data-serving-side="B">
                <strong id="scoreTeamB"></strong>
                <div class="score-step-row">
                  <button type="button" class="btn score-step-btn" data-score-target="B" data-score-delta="-1">-</button>
                  <div id="scoreInputB" class="live-score-number">0</div>
                  <button type="button" class="btn btn-success score-step-btn" data-score-target="B" data-score-delta="1">+</button>
                </div>
              </div>
            </div>
            <div class="score-options">
              <span>Đội đang giao</span>
              <button type="button" class="btn btn-sm" data-serving-select="A">Đội A</button>
              <button type="button" class="btn btn-sm" data-serving-select="B">Đội B</button>
            </div>
            <div class="score-options">
              <span>Thứ tự đánh</span>
              <button type="button" class="btn btn-sm" data-score-order-select="1">1</button>
              <button type="button" class="btn btn-sm" data-score-order-select="2">2</button>
            </div>
            <div id="scoreSaveStatus" class="score-save-status muted">Chưa thay đổi</div>
          </div>
        </div>
      </div>
    <% } %>
  <% } %>

  <% if (section === 'fees') { %>
    <section class="card-lite p"><div class="section-heading mb"><div><span class="feature-icon">💳</span><h2 class="section-title">Danh sách đóng phí</h2><p class="muted">Dòng xanh là đủ phí, dòng vàng là còn thiếu.</p></div></div>
      <% if (currentUser.role === 'ADMIN') { %><form method="post" action="/tournaments/<%= tournament.id %>/payments"><% } %>
      <div class="table-wrap"><table><thead><tr><th>Tên</th><th>Số tiền</th><th>Trạng thái</th></tr></thead><tbody>
        <% registrations.forEach((r) => { const feeAmount = Number(r.paidAmount || 0) > 0 ? Number(r.paidAmount) : minimumFee; const mine = String(r.player ? r.player.email : r.externalEmail || '').toLowerCase() === currentEmail; %><tr class="<%= feeAmount >= minimumFee ? 'sufficient-row' : 'insufficient-row' %> <%= mine ? 'mine-row' : '' %>"><td><strong><%= r.player ? r.player.displayName : r.externalName %></strong></td><% if (currentUser.role === 'ADMIN') { %><td><input class="money-input" name="amount_<%= r.id %>" value="<%= formatMoney(feeAmount) %>"></td><td><select class="payment-status-select" name="status_<%= r.id %>"><option value="UNPAID" <%= r.paymentStatus === 'UNPAID' ? 'selected' : '' %>>✕</option><option value="PAID" <%= r.paymentStatus === 'PAID' ? 'selected' : '' %>>✓</option></select></td><% } else { %><td><%= formatMoney(feeAmount) %>đ</td><td><span class="payment-mark <%= r.paymentStatus === 'PAID' ? 'paid' : 'unpaid' %>"><%= r.paymentStatus === 'PAID' ? '✓' : '✕' %></span></td><% } %></tr><% }) %>
      </tbody></table></div>
      <% if (currentUser.role === 'ADMIN') { %><div class="mt text-right"><button class="btn btn-primary" data-loading-text="Đang lưu...">Lưu tất cả</button></div></form><% } %>
    </section>
  <% } %>

  <% if (section === 'settings') { %>
    <section class="card-lite p">
      <div class="section-heading mb"><div><span class="feature-icon">⚙️</span><h2 class="section-title">Cài đặt giải đấu</h2><p class="muted">Thông tin cấu hình, thao tác sửa và xóa giải.</p></div></div>
      <div class="grid module-grid">
        <div><span class="muted">Tên giải</span><br><strong><%= tournament.name %></strong></div>
        <div><span class="muted">Địa điểm</span><br><strong><%= tournament.venue || 'Chưa có' %></strong></div>
        <div><span class="muted">Bắt đầu</span><br><strong><%= tournament.startTime ? new Date(tournament.startTime).toLocaleString('vi-VN') : 'Chưa có' %></strong></div>
        <div><span class="muted">Kết thúc</span><br><strong><%= tournament.endTime ? new Date(tournament.endTime).toLocaleString('vi-VN') : 'Chưa có' %></strong></div>
        <div><span class="muted">Số sân</span><br><strong><%= tournament.courtCount %></strong></div>
        <div><span class="muted">Số thành viên dự kiến</span><br><strong><%= tournament.expectedPlayers %></strong></div>
        <div><span class="muted">Loại đấu</span><br><strong><%= tournament.playType === 'DOUBLES' ? 'Thi đôi' : 'Thi đơn' %></strong></div>
        <div><span class="muted">Thể thức</span><br><strong><%= tournament.format === 'GROUP_KNOCKOUT' ? 'Vòng bảng + loại trực tiếp' : 'Vòng tròn' %></strong></div>
        <div><span class="muted">Điểm</span><br><strong>Vòng bảng: chạm <%= tournament.touchScore %>, max <%= tournament.maxScore %><% if (tournament.format === 'GROUP_KNOCKOUT') { %><br>Vòng trong: chạm <%= tournament.knockoutTouchScore || 15 %>, max <%= tournament.knockoutMaxScore || 19 %><% } %></strong></div>
        <div><span class="muted">Đăng ký ngoài</span><br><strong><%= tournament.externalRegistrationEnabled ? 'Đang mở' : 'Đang tắt' %></strong></div>
      </div>
      <div class="mt flex gap">
        <a class="btn btn-primary" href="/tournaments/<%= tournament.id %>/edit?returnSection=<%= section %>">Sửa cấu hình giải</a>
        <% if (currentUser.role === 'ADMIN') { %><form method="post" action="/tournaments/<%= tournament.id %>/delete" data-confirm="Xóa giải này và toàn bộ dữ liệu liên quan?"><button class="btn btn-danger" data-loading-text="Đang xóa...">Xóa giải</button></form><% } %>
      </div>
    </section>
  <% } %>
</main>
<nav class="bottom-menu"><button class="mobile-menu-toggle" type="button" data-menu-toggle aria-label="Mở menu">☰</button><div class="bottom-menu-inner">
  <% (currentUser.role === 'ADMIN' ? ['players','fund','ranking','schedule','fees','settings'] : ['players','fund','ranking','schedule','fees']).forEach((item) => { const labels = {players:'👥 Thành viên', fund:'🏆 Quỹ', ranking:'📊 BXH', schedule:'🗓️ Thi đấu', fees:'💳 Đóng phí', settings:'⚙️ Cài đặt'}; %><a class="<%= section === item ? 'active' : '' %>" href="/tournaments/<%= tournament.id %>/<%= item %>"><%= labels[item] %></a><% }) %>
</div></nav>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/app.js"></script>
</body></html>
