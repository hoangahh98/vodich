<%- include('../partials/head', { title: tournament.name }) %>
<%- include('../partials/topbar') %>
<% const paymentLabels = { PAID: 'Đã đóng', UNPAID: 'Chưa đóng' }; %>
<main class="app-shell">
  <section class="card-lite p mb">
    <div class="flex between center">
      <div>
        <h1><%= tournament.name %></h1>
        <div class="muted"><%= tournament.venue || 'Chưa có địa điểm' %> · Phí tối thiểu <%= formatMoney(Number(tournament.courtCost) + Number(tournament.foodCost) + Number(tournament.prizeCost) + Number(tournament.otherCost)) %>đ · <%= tournament.format === 'GROUP_KNOCKOUT' ? 'Vòng bảng + loại trực tiếp' : 'Vòng tròn' %></div>
      </div>
      <div class="flex gap">
        <% if (currentUser.role === 'ADMIN') { %>
          <a class="btn btn-sm btn-primary" href="/tournaments/<%= tournament.id %>/edit">Sửa giải</a>
          <form method="post" action="/tournaments/<%= tournament.id %>/delete" onsubmit="return confirm('Xóa giải này và toàn bộ dữ liệu liên quan?')"><button class="btn btn-sm btn-danger" data-loading-text="Đang xóa...">Xóa</button></form>
        <% } %>
        <a class="btn btn-sm" href="/tournaments">Danh sách</a>
      </div>
    </div>
  </section>

  <% if (section === 'players') { %>
    <section class="card-lite p">
      <div class="flex between center mb"><h2 class="section-title">Thành viên</h2><span class="badge"><%= registrations.length %>/<%= tournament.expectedPlayers %></span></div>
      <% if (tournament.externalRegistrationEnabled) { %><div class="card-lite p mb"><strong>Link đăng ký ngoài</strong><input value="<%= externalLink %>" readonly></div><% } %>
      <% if (currentUser.role === 'ADMIN') { %>
        <form class="row mb" method="post" action="/tournaments/<%= tournament.id %>/registrations">
          <div class="col-6"><select name="playerId" required><option value="">Chọn thành viên có sẵn</option><% players.forEach((p) => { %><option value="<%= p.id %>"><%= p.displayName %> · <%= p.skillLevel || 'Chưa chọn trình' %></option><% }) %></select></div>
          <div class="col-2"><button class="btn btn-success" data-loading-text="Đang thêm...">Thêm</button></div>
        </form>
      <% } %>
      <div class="table-wrap"><table><thead><tr><th>Tên</th><th>Trình</th><th>Nguồn</th><th></th></tr></thead><tbody>
        <% registrations.forEach((r) => { %><tr><td><strong><%= r.player ? r.player.displayName : r.externalName %></strong></td><td><span class="badge"><%= r.skillLevel || '-' %></span></td><td><%= r.source === 'EXTERNAL' ? 'Đăng ký ngoài' : 'Danh sách chung' %></td><td class="text-right"><% if (currentUser.role === 'ADMIN') { %><form method="post" action="/registrations/<%= r.id %>/withdraw"><input type="hidden" name="tournamentId" value="<%= tournament.id %>"><button class="btn btn-sm">Bỏ giải</button></form><% } %></td></tr><% }) %>
      </tbody></table></div>
      <% if (withdrawnRegistrations.length) { %><h3>Bỏ giải</h3><% withdrawnRegistrations.forEach((r) => { %><div class="flex between center card-lite p mb"><span><%= r.player ? r.player.displayName : r.externalName %></span><form method="post" action="/registrations/<%= r.id %>/restore"><input type="hidden" name="tournamentId" value="<%= tournament.id %>"><button class="btn btn-sm">Khôi phục</button></form></div><% }) %><% } %>
    </section>
  <% } %>

  <% if (section === 'fund') { %>
    <section class="card-lite p"><h2>Quỹ giải</h2><div class="grid module-grid"><div>Sân bãi<br><strong><%= formatMoney(tournament.courtCost) %>đ</strong></div><div>Ăn uống<br><strong><%= formatMoney(tournament.foodCost) %>đ</strong></div><div>Giải thưởng<br><strong><%= formatMoney(tournament.prizeCost) %>đ</strong></div><div>Khác<br><strong><%= formatMoney(tournament.otherCost) %>đ</strong></div></div></section>
  <% } %>

  <% if (section === 'ranking') { %>
    <section class="card-lite p"><h2>Bảng xếp hạng</h2>
      <% if (!rankingGroups.length) { %><p class="muted">Chưa có lịch thi đấu để tính xếp hạng.</p><% } %>
      <% rankingGroups.forEach((group) => { %>
        <h3><%= tournament.format === 'ROUND_ROBIN' ? 'BXH' : `BXH - Bảng ${group.groupName}` %></h3>
        <div class="table-wrap"><table><thead><tr><th>#</th><th>Đội</th><th>Trận</th><th>Thắng</th><th>Thua</th><th>Điểm</th><th>Hiệu số</th></tr></thead><tbody>
          <% group.rows.forEach((row, index) => { %><tr><td><%= index + 1 %></td><td><strong><%= row.teamName %></strong></td><td><%= row.played %></td><td><%= row.won %></td><td><%= row.lost %></td><td><span class="badge bg-primary"><%= row.rankingPoints %></span></td><td><%= row.pointDiff > 0 ? '+' : '' %><%= row.pointDiff %></td></tr><% }) %>
        </tbody></table></div>
      <% }) %>
    </section>
  <% } %>

  <% if (section === 'schedule') { %>
    <section class="card-lite p">
      <div class="flex between center mb"><div><h2>Lịch thi đấu</h2><% if (tournament.format === 'GROUP_KNOCKOUT') { %><div class="muted">Vào vòng trong: <%= tournament.knockoutQualifierCount %> đội</div><% } %></div><% if (currentUser.role === 'ADMIN') { %><form method="post" action="/tournaments/<%= tournament.id %>/generate-schedule"><button class="btn btn-primary" data-loading-text="Đang chia...">Chia lịch</button></form><% } %></div>
      <div id="matchList" data-tournament-id="<%= tournament.id %>" data-touch-score="<%= tournament.touchScore || 11 %>" data-max-score="<%= tournament.maxScore || 15 %>">
        <%
          const roundMap = new Map();
          matches.forEach((match) => {
            const list = roundMap.get(match.roundNumber) || [];
            list.push(match);
            roundMap.set(match.roundNumber, list);
          });
          const roundTitle = (round, list) => {
            const stage = list.find((item) => item.stage !== 'Vòng bảng' && item.stage !== 'Vòng tròn')?.stage;
            if (stage) return `🏆 ${stage.toUpperCase()}`;
            if (round === 100) return '🏆 TỨ KẾT';
            if (round === 101) return '🏆 BÁN KẾT';
            if (round === 102) return '🏆 CHUNG KẾT';
            return tournament.format === 'GROUP_KNOCKOUT' ? `🔄 LƯỢT ${round}` : `🔄 VÒNG ${round}`;
          };
        %>
        <% if (!matches.length) { %>
          <div class="text-center py-4">
            <p class="muted mb">Chưa có lịch thi đấu. Bấm bên trên để tự động sinh lịch.</p>
            <% if (currentUser.role === 'ADMIN') { %>
              <form method="post" action="/tournaments/<%= tournament.id %>/generate-schedule"><button class="btn btn-primary" data-loading-text="Đang chia...">⚡ TỰ ĐỘNG SINH LỊCH</button></form>
            <% } %>
          </div>
        <% } %>
        <% if (tournament.format === 'GROUP_KNOCKOUT' && groupBoards && groupBoards.length) { %>
          <div class="mb-4">
            <div class="vong-header rounded px-3 py-2 mb-3 fw-bold text-success">📋 DANH SÁCH BẢNG ĐẤU</div>
            <div class="grid group-grid">
              <% groupBoards.forEach((group) => { %>
                <div class="group-board">
                  <div class="group-board-title">Bảng <%= group.groupName %></div>
                  <% group.teams.forEach((team) => { %>
                    <div class="group-team-row"><%= team %></div>
                  <% }) %>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
        <% Array.from(roundMap.entries()).forEach(([round, roundMatches]) => { 
          const doneCount = roundMatches.filter((item) => item.status === 'FINISHED').length;
          const courtMap = new Map();
          roundMatches.forEach((match) => {
            const list = courtMap.get(match.courtNumber) || [];
            list.push(match);
            courtMap.set(match.courtNumber, list);
          });
          const courts = Array.from(courtMap.entries());
        %>
          <div class="mb-4">
            <div class="vong-header rounded px-3 py-2 mb-3 fw-bold text-primary">
              <%= roundTitle(round, roundMatches) %> — <%= roundMatches.length %> trận
              <small class="text-muted fw-normal ms-2">(<%= doneCount %> đã xong)</small>
            </div>
            <div class="grid courts-grid">
              <% courts.forEach(([court, courtMatches]) => { %>
                <div class="court-column">
                  <div class="border rounded p-2 h-100" style="border-color:#0d6efd44!important;">
                    <div class="text-center fw-bold small text-primary mb-2">🏟️ SÂN <%= court %></div>
                    <% courtMatches.forEach((m) => { const knockout = m.stage !== 'Vòng bảng' && m.stage !== 'Vòng tròn'; const done = m.status === 'FINISHED'; %>
                      <div class="tran-card rounded p-2 mb-2 <%= done ? 'da-xong' : '' %> <%= knockout ? 'knockout' : '' %>" data-match-id="<%= m.id %>">
                        <div class="match-meta">
                          <% if (m.stage === 'Vòng bảng') { %>
                            <span class="badge bg-success">Lượt <%= round %></span>
                            <span class="badge bg-info text-dark">Bảng <%= m.groupName || 'A' %></span>
                          <% } else if (knockout) { %>
                            <span class="badge bg-danger"><%= m.stage %></span>
                          <% } else { %>
                            <span class="badge bg-primary">Vòng <%= round %></span>
                          <% } %>
                          <span class="badge bg-secondary">Sân <%= court %></span>
                        </div>
                        <div class="match-grid">
                          <div class="team-name">
                            <% String(m.teamA).split(' / ').forEach((name) => { %><span><%= name %></span><% }) %>
                          </div>
                          <div class="score-section">
                            <span class="badge <%= done ? 'bg-success' : 'bg-primary' %> px-2 py-1 score-pill">
                              <span class="score-a"><%= m.scoreA %></span> – <span class="score-b"><%= m.scoreB %></span> - <span class="score-order"><%= m.scoreOrder || 2 %></span>
                            </span>
                            <span class="badge <%= done ? 'bg-success' : 'bg-secondary' %> match-status"><%= done ? 'Đã xong' : 'Đang đánh' %></span>
                            <% if (currentUser.role === 'ADMIN') { %>
                              <div class="score-controls mt-1">
                                <button class="btn btn-sm" data-side="A" data-delta="-1">-</button>
                                <button class="btn btn-sm" data-side="A" data-delta="1">+A</button>
                                <button class="btn btn-sm" data-side="B" data-delta="-1">-</button>
                                <button class="btn btn-sm" data-side="B" data-delta="1">+B</button>
                              </div>
                            <% } %>
                          </div>
                          <div class="team-name text-end">
                            <% String(m.teamB).split(' / ').forEach((name) => { %><span><%= name %></span><% }) %>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (section === 'fees') { %>
    <section class="card-lite p"><h2>Danh sách đóng phí</h2><div class="table-wrap"><table><thead><tr><th>Tên</th><th>Tiền</th><th>Trạng thái</th></tr></thead><tbody>
      <% registrations.forEach((r) => { %><tr><td><%= r.player ? r.player.displayName : r.externalName %></td><td><% if (currentUser.role === 'ADMIN') { %><form class="flex gap" method="post" action="/registrations/<%= r.id %>/payment"><input type="hidden" name="tournamentId" value="<%= tournament.id %>"><input class="money-input" name="amount" value="<%= formatMoney(r.paidAmount) %>"><select name="status"><option value="UNPAID" <%= r.paymentStatus === 'UNPAID' ? 'selected' : '' %>>Chưa đóng</option><option value="PAID" <%= r.paymentStatus === 'PAID' ? 'selected' : '' %>>Đã đóng</option></select><button class="btn btn-primary" data-loading-text="Đang lưu...">Lưu</button></form><% } else { %><%= formatMoney(r.paidAmount) %>đ<% } %></td><td><%= paymentLabels[r.paymentStatus] || r.paymentStatus %></td></tr><% }) %>
    </tbody></table></div></section>
  <% } %>

  <% if (section === 'settings') { %><section class="card-lite p"><h2>Cài đặt</h2><p class="muted">Màn sửa giải chi tiết sẽ được tách tiếp, hiện tạo mới đã đủ cấu hình chính.</p></section><% } %>
</main>
<nav class="bottom-menu"><div class="bottom-menu-inner">
  <% ['players','fund','ranking','schedule','fees','settings'].forEach((item) => { const labels = {players:'Thành viên', fund:'Quỹ', ranking:'BXH', schedule:'Lịch', fees:'Đóng phí', settings:'Cài đặt'}; %><a class="<%= section === item ? 'active' : '' %>" href="/tournaments/<%= tournament.id %>/<%= item %>"><%= labels[item] %></a><% }) %>
</div></nav>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/app.js"></script>
</body></html>
