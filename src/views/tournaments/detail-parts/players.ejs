  <% if (section === 'players') { %>
    <section class="card-lite p">
      <div class="section-heading mb"><div><span class="feature-icon">👥</span><h2 class="section-title">Thành viên</h2><p class="muted">Quản lý chính thức, dự bị và thao tác nhiều người một lúc.</p></div><span class="badge"><%= registrations.length %>/<%= tournament.expectedPlayers %></span></div>
      <% if (currentUser.role === 'ADMIN' && tournament.externalRegistrationEnabled) { %><div class="card-lite p mb"><strong>Link đăng ký ngoài</strong><div class="copy-field mt"><input id="externalRegistrationLink" value="<%= externalLink %>" readonly><button class="btn btn-primary" type="button" data-copy-target="externalRegistrationLink">Copy</button></div></div><% } %>
      <% if (currentUser.role === 'ADMIN') { %>
        <form id="addTournamentPlayersForm" class="mb" method="post" action="/tournaments/<%= tournament.id %>/registrations">
          <% const usedPlayerIds = new Set([...registrations, ...(reserveRegistrations || []), ...withdrawnRegistrations].map((r) => r.playerId && r.playerId.toString()).filter(Boolean)); %>
          <div id="playerSlotHint" class="alert-lite <%= slotsLeft > 0 ? 'info' : 'warn' %> mb" data-slots-left="<%= slotsLeft %>">Còn <strong data-slot-count><%= slotsLeft %></strong> suất chính thức. Đã chọn <strong data-selected-count>0</strong> thành viên.</div>
          <div class="player-check-list mb" data-player-picker>
            <% players.filter((p) => !usedPlayerIds.has(p.id.toString())).forEach((p) => { %>
              <label><input type="checkbox" name="playerId" value="<%= p.id %>"><span><strong><%= p.displayName %></strong><small><%= p.email %> · <%= p.skillLevel || 'Chưa chọn trình' %></small></span></label>
            <% }) %>
          </div>
          <button class="btn btn-success" data-loading-text="Đang thêm...">Thêm thành viên đã chọn</button>
        </form>
      <% } %>
      <form class="registration-panel" method="post" action="/tournaments/<%= tournament.id %>/registrations/bulk" <%= currentUser.role === 'ADMIN' ? 'data-require-checked="registrationIds" data-confirm="Xử lý các thành viên đã chọn?"' : '' %>>
        <div class="bulk-toolbar mb"><strong>Chính thức</strong><span class="muted"><%= registrations.length %> thành viên</span><% if (currentUser.role === 'ADMIN') { %><div class="flex gap"><button class="btn btn-sm" name="bulkAction" value="withdraw" data-loading-text="Đang bỏ giải...">Bỏ giải đã chọn</button><button class="btn btn-sm btn-danger" name="bulkAction" value="delete" data-loading-text="Đang xóa...">Xóa đã chọn</button></div><% } %></div>
        <div class="table-wrap"><table><thead><tr><% if (currentUser.role === 'ADMIN') { %><th class="check-col"><input type="checkbox" data-check-all="[data-active-registration]"></th><% } %><th>Tên</th><th>Trình</th></tr></thead><tbody>
          <% registrations.forEach((r) => { const mine = String(r.player ? r.player.email : r.externalEmail || '').toLowerCase() === currentEmail; %><tr class="<%= mine ? 'mine-row' : '' %>"><% if (currentUser.role === 'ADMIN') { %><td><input data-active-registration type="checkbox" name="registrationIds" value="<%= r.id %>"></td><% } %><td><strong><%= r.player ? r.player.displayName : r.externalName %></strong><% if (currentUser.role === 'ADMIN') { %><br><span class="muted"><%= r.player ? r.player.email : r.externalEmail || '-' %></span><% } %><br><span class="muted"><%= r.source === 'EXTERNAL' ? 'Đăng ký ngoài' : 'Danh sách chung' %></span></td><td><% if (currentUser.role === 'ADMIN' && r.source === 'EXTERNAL') { %><input type="hidden" name="tournamentId" value="<%= tournament.id %>" form="skill-<%= r.id %>"><select name="skillLevel" form="skill-<%= r.id %>" data-autosubmit><option value="" <%= !r.skillLevel ? 'selected' : '' %>>Chưa chọn</option><% ['A','B','C','D'].forEach((level) => { %><option value="<%= level %>" <%= r.skillLevel === level ? 'selected' : '' %>><%= level %></option><% }) %></select><% } else { %><span class="badge"><%= r.skillLevel || '-' %></span><% } %></td></tr><% }) %>
          <% if (!registrations.length) { %><tr><td colspan="<%= currentUser.role === 'ADMIN' ? 3 : 2 %>" class="muted text-center">Chưa có thành viên chính thức.</td></tr><% } %>
        </tbody></table></div>
      </form>
      <% if (reserveRegistrations && reserveRegistrations.length) { %>
        <form class="registration-panel mt" method="post" action="/tournaments/<%= tournament.id %>/registrations/bulk" <%= currentUser.role === 'ADMIN' ? 'data-require-checked="registrationIds" data-confirm="Xử lý các thành viên dự bị đã chọn?"' : '' %>>
          <div class="bulk-toolbar mb"><strong>Dự bị</strong><span class="muted"><%= reserveRegistrations.length %> thành viên</span><% if (currentUser.role === 'ADMIN') { %><div class="flex gap"><button class="btn btn-sm" name="bulkAction" value="restore" <%= slotsLeft <= 0 ? 'disabled title="Đã đủ thành viên chính thức"' : '' %> data-loading-text="Đang đưa vào giải...">Đưa vào giải</button><button class="btn btn-sm" name="bulkAction" value="withdraw" data-loading-text="Đang bỏ giải...">Bỏ giải đã chọn</button><button class="btn btn-sm btn-danger" name="bulkAction" value="delete" data-loading-text="Đang xóa...">Xóa đã chọn</button></div><% } %></div>
          <div class="table-wrap"><table><thead><tr><% if (currentUser.role === 'ADMIN') { %><th class="check-col"><input type="checkbox" data-check-all="[data-reserve-registration]"></th><% } %><th>Tên</th><th>Trình</th></tr></thead><tbody>
            <% reserveRegistrations.forEach((r) => { const mine = String(r.player ? r.player.email : r.externalEmail || '').toLowerCase() === currentEmail; %><tr class="insufficient-row <%= mine ? 'mine-row' : '' %>"><% if (currentUser.role === 'ADMIN') { %><td><input data-reserve-registration type="checkbox" name="registrationIds" value="<%= r.id %>"></td><% } %><td><strong><%= r.player ? r.player.displayName : r.externalName %></strong><% if (currentUser.role === 'ADMIN') { %><br><span class="muted"><%= r.player ? r.player.email : r.externalEmail || '-' %></span><% } %><br><span class="muted"><%= r.source === 'EXTERNAL' ? 'Đăng ký ngoài' : 'Danh sách chung' %></span></td><td><% if (currentUser.role === 'ADMIN' && r.source === 'EXTERNAL') { %><input type="hidden" name="tournamentId" value="<%= tournament.id %>" form="skill-<%= r.id %>"><select name="skillLevel" form="skill-<%= r.id %>" data-autosubmit><option value="" <%= !r.skillLevel ? 'selected' : '' %>>Chưa chọn</option><% ['A','B','C','D'].forEach((level) => { %><option value="<%= level %>" <%= r.skillLevel === level ? 'selected' : '' %>><%= level %></option><% }) %></select><% } else { %><span class="badge"><%= r.skillLevel || '-' %></span><% } %></td></tr><% }) %>
          </tbody></table></div>
        </form>
      <% } %>
      <% if (withdrawnRegistrations.length) { %><div class="registration-panel mt"><div class="bulk-toolbar mb"><strong>Bỏ giải</strong><span class="muted"><%= withdrawnRegistrations.length %> thành viên</span></div><% withdrawnRegistrations.forEach((r) => { %><div class="flex between center card-lite p mb"><span><%= r.player ? r.player.displayName : r.externalName %></span><form method="post" action="/registrations/<%= r.id %>/restore"><input type="hidden" name="tournamentId" value="<%= tournament.id %>"><button class="btn btn-sm" data-loading-text="Đang khôi phục...">Khôi phục</button></form></div><% }) %></div><% } %>
      <% if (currentUser.role === 'ADMIN') { [...registrations, ...(reserveRegistrations || [])].filter((r) => r.source === 'EXTERNAL').forEach((r) => { %><form id="skill-<%= r.id %>" method="post" action="/registrations/<%= r.id %>/skill"></form><% }) } %>
    </section>
  <% } %>

