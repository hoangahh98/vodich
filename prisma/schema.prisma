generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppUser {
  id           BigInt   @id @default(autoincrement())
  username     String   @unique @db.VarChar(120)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  displayName  String   @map("display_name") @db.VarChar(255)
  role         String   @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at")

  permissions           AdminFeaturePermission[]
  ownedTournaments      Tournament[]             @relation("TournamentOwner")
  tournamentPermissions TournamentPermission[]
  ownedTeams            TeamClub[]               @relation("TeamClubOwner")
  teamPermissions       TeamClubPermission[]
  ownedTravelTrips      TravelTrip[]             @relation("TravelTripOwner")
  travelPermissions     TravelTripPermission[]
  knightCharacters      KnightCharacter[]        @relation("KnightCharacterOwner")

  @@map("app_user")
}

model AdminFeaturePermission {
  id      BigInt  @id @default(autoincrement())
  adminId BigInt  @map("admin_id")
  feature String  @db.VarChar(40)
  admin   AppUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, feature])
  @@map("admin_feature_permission")
}

model Player {
  id          BigInt   @id @default(autoincrement())
  displayName String   @map("display_name") @db.VarChar(255)
  email       String   @unique @db.VarChar(255)
  skillLevel  String?  @map("skill_level") @db.VarChar(10)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  registrations TournamentRegistration[]
  teamMembers   TeamMember[]
  travelPeople  TravelPerson[]
  travelMembers TravelTripMember[]

  @@map("player")
}

model Tournament {
  id                          BigInt    @id @default(autoincrement())
  name                        String    @db.VarChar(255)
  venue                       String?   @db.VarChar(255)
  startTime                   DateTime? @map("start_time")
  endTime                     DateTime? @map("end_time")
  courtCount                  Int       @default(1) @map("court_count")
  expectedPlayers             Int       @default(10) @map("expected_players")
  playType                    String    @default("SINGLES") @map("play_type") @db.VarChar(20)
  format                      String    @default("ROUND_ROBIN") @db.VarChar(20)
  knockoutQualifierCount      Int       @default(4) @map("knockout_qualifier_count")
  touchScore                  Int       @default(11) @map("touch_score")
  maxScore                    Int       @default(15) @map("max_score")
  knockoutTouchScore          Int       @default(15) @map("knockout_touch_score")
  knockoutMaxScore            Int       @default(19) @map("knockout_max_score")
  courtCost                   Decimal   @default(0) @map("court_cost") @db.Decimal(14, 2)
  foodCost                    Decimal   @default(0) @map("food_cost") @db.Decimal(14, 2)
  prizeCost                   Decimal   @default(0) @map("prize_cost") @db.Decimal(14, 2)
  otherCost                   Decimal   @default(0) @map("other_cost") @db.Decimal(14, 2)
  prizeRate1                  Decimal   @default(50) @map("prize_rate_1") @db.Decimal(14, 2)
  prizeRate2                  Decimal   @default(30) @map("prize_rate_2") @db.Decimal(14, 2)
  prizeRate3                  Decimal   @default(20) @map("prize_rate_3") @db.Decimal(14, 2)
  externalRegistrationEnabled Boolean   @default(false) @map("external_registration_enabled")
  ownerAdminId                BigInt?   @map("owner_admin_id")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @default(now()) @map("updated_at")

  ownerAdmin    AppUser?                 @relation("TournamentOwner", fields: [ownerAdminId], references: [id], onDelete: SetNull)
  registrations TournamentRegistration[]
  matches       MatchGame[]
  permissions   TournamentPermission[]

  @@map("tournament")
}

model TournamentPermission {
  id           BigInt   @id @default(autoincrement())
  tournamentId BigInt   @map("tournament_id")
  adminId      BigInt   @map("admin_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  admin      AppUser    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, adminId])
  @@map("tournament_permission")
}

model TournamentRegistration {
  id            BigInt    @id @default(autoincrement())
  tournamentId  BigInt    @map("tournament_id")
  playerId      BigInt?   @map("player_id")
  externalName  String?   @map("external_name") @db.VarChar(255)
  externalEmail String?   @map("external_email") @db.VarChar(255)
  skillLevel    String?   @map("skill_level") @db.VarChar(10)
  source        String    @default("INTERNAL") @db.VarChar(20)
  status        String    @default("ACTIVE") @db.VarChar(20)
  paidAmount    Decimal   @default(0) @map("paid_amount") @db.Decimal(14, 2)
  paymentStatus String    @default("UNPAID") @map("payment_status") @db.VarChar(40)
  withdrawnAt   DateTime? @map("withdrawn_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player?    @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, playerId])
  @@unique([tournamentId, externalEmail])
  @@map("tournament_registration")
}

model MatchGame {
  id           BigInt   @id @default(autoincrement())
  tournamentId BigInt   @map("tournament_id")
  teamA        String   @map("team_a") @db.VarChar(255)
  teamB        String   @map("team_b") @db.VarChar(255)
  scoreA       Int      @default(0) @map("score_a")
  scoreB       Int      @default(0) @map("score_b")
  status       String   @default("SCHEDULED") @db.VarChar(30)
  courtNumber  Int      @default(1) @map("court_number")
  roundNumber  Int      @default(1) @map("round_number")
  stage        String   @default("Vòng tròn") @db.VarChar(40)
  groupName    String?  @map("group_name") @db.VarChar(20)
  servingTeam  String   @default("A") @map("serving_team") @db.VarChar(1)
  scoreOrder   Int      @default(2) @map("score_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("match_game")
}

model TeamClub {
  id           BigInt   @id @default(autoincrement())
  name         String   @db.VarChar(255)
  description  String?
  ownerAdminId BigInt?  @map("owner_admin_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  ownerAdmin  AppUser?             @relation("TeamClubOwner", fields: [ownerAdminId], references: [id], onDelete: SetNull)
  members     TeamMember[]
  funds       TeamMonthFund[]
  expenses    TeamExpense[]
  permissions TeamClubPermission[]

  @@map("team_club")
}

model TeamClubPermission {
  id        BigInt   @id @default(autoincrement())
  teamId    BigInt   @map("team_id")
  adminId   BigInt   @map("admin_id")
  createdAt DateTime @default(now()) @map("created_at")

  team  TeamClub @relation(fields: [teamId], references: [id], onDelete: Cascade)
  admin AppUser  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([teamId, adminId])
  @@map("team_club_permission")
}

model TeamMember {
  id         BigInt   @id @default(autoincrement())
  teamId     BigInt   @map("team_id")
  playerId   BigInt   @map("player_id")
  memberType String   @default("FIXED") @map("member_type") @db.VarChar(20)
  active     Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  team     TeamClub            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player   Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  payments TeamMemberPayment[]

  @@unique([teamId, playerId])
  @@map("team_member")
}

model TeamMonthFund {
  id              BigInt   @id @default(autoincrement())
  teamId          BigInt   @map("team_id")
  fundMonth       DateTime @map("fund_month") @db.Date
  monthlyFee      Decimal  @default(0) @map("monthly_fee") @db.Decimal(14, 2)
  courtCost       Decimal  @default(0) @map("court_cost") @db.Decimal(14, 2)
  previousBalance Decimal  @default(0) @map("previous_balance") @db.Decimal(14, 2)
  notes           String?

  team TeamClub @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, fundMonth])
  @@map("team_month_fund")
}

model TeamMemberPayment {
  id            BigInt   @id @default(autoincrement())
  memberId      BigInt   @map("member_id")
  fundMonth     DateTime @map("fund_month") @db.Date
  paidAmount    Decimal  @default(0) @map("paid_amount") @db.Decimal(14, 2)
  paymentStatus String   @default("UNPAID") @map("payment_status") @db.VarChar(40)
  notes         String?

  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, fundMonth])
  @@map("team_member_payment")
}

model TeamExpense {
  id           BigInt    @id @default(autoincrement())
  teamId       BigInt    @map("team_id")
  expenseMonth DateTime  @map("expense_month") @db.Date
  expenseDate  DateTime? @map("expense_date") @db.Date
  content      String    @db.VarChar(255)
  amount       Decimal   @default(0) @db.Decimal(14, 2)
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @map("updated_at")

  team TeamClub @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_expense")
}

// ===== Game "Hiệp Sĩ Toán Học" (RPG học toán 4-7 tuổi) =====
// Hồ sơ nhân vật của người chơi: lưu tiến trình liên tục (Save/Load).
model KnightCharacter {
  id           BigInt   @id @default(autoincrement())
  ownerUserId  BigInt   @map("owner_user_id")
  name         String   @db.VarChar(60)
  gender       String   @default("boy") @db.VarChar(10) // 'boy' | 'girl'
  age          Int // 4..7
  notes        String   @default("") // Ghi chú cá nhân: điểm mạnh/yếu, sở thích
  currentStage Int      @default(1) @map("current_stage") // màn chơi hiện tại
  mobIndex     Int      @default(0) @map("mob_index") // đã đánh tới con quái thứ mấy của ải (chơi tiếp đúng chỗ)
  hp           Int      @default(10) // máu còn lại của lượt chơi hiện tại
  status       String   @default("ACTIVE") @db.VarChar(20) // ACTIVE | RESTING | VICTORY
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  owner    AppUser          @relation("KnightCharacterOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  progress KnightProgress[]

  @@map("knight_character")
}

// Tiến trình từng ải đã vượt qua (lịch sử + số sao). Tra cứu bằng khoá chính xác
// [characterId, stageNumber] — không dùng lọc theo khoảng.
model KnightProgress {
  id          BigInt   @id @default(autoincrement())
  characterId BigInt   @map("character_id")
  stageNumber Int      @map("stage_number")
  status      String   @default("CLEARED") @db.VarChar(20) // CLEARED
  stars       Int      @default(0) // 0..3
  attempts    Int      @default(1)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  character KnightCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, stageNumber])
  @@map("knight_progress")
}

model AppLog {
  id           BigInt   @id @default(autoincrement())
  createdAt    DateTime @default(now()) @map("created_at")
  level        String   @db.VarChar(20)
  category     String   @db.VarChar(80)
  action       String   @db.VarChar(255)
  method       String?  @db.VarChar(12)
  path         String?  @db.VarChar(500)
  queryString  String?  @map("query_string")
  statusCode   Int?     @map("status_code")
  durationMs   BigInt?  @map("duration_ms")
  userId       BigInt?  @map("user_id")
  username     String?  @db.VarChar(255)
  userRole     String?  @map("user_role") @db.VarChar(30)
  ipAddress    String?  @map("ip_address") @db.VarChar(120)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  details      String?
  errorMessage String?  @map("error_message")

  @@map("app_log")
}

model MedPatient {
  id           BigInt   @id @default(autoincrement())
  name         String   @db.VarChar(255)
  birthYear    Int?     @map("birth_year")
  gender       String?  @db.VarChar(20)
  allergies    String?
  conditions   String?
  notes        String?
  ownerAdminId BigInt?  @map("owner_admin_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  prescriptions MedPrescription[]

  @@map("med_patient")
}

model MedPrescription {
  id             BigInt    @id @default(autoincrement())
  patientId      BigInt    @map("patient_id")
  prescribedDate DateTime? @map("prescribed_date") @db.Date
  doctor         String    @default("") @db.VarChar(255)
  clinic         String    @default("") @db.VarChar(255)
  diagnosis      String    @default("")
  imageData      String?   @map("image_data")
  imageMime      String?   @map("image_mime") @db.VarChar(80)
  aiSummary      String?   @map("ai_summary")
  aiRisk         String?   @map("ai_risk") @db.VarChar(20)
  createdAt      DateTime  @default(now()) @map("created_at")

  patient MedPatient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items   MedPrescriptionItem[]

  @@map("med_prescription")
}

model MedPrescriptionItem {
  id             BigInt  @id @default(autoincrement())
  prescriptionId BigInt  @map("prescription_id")
  drugName       String  @map("drug_name") @db.VarChar(255)
  isAntibiotic   Boolean @default(false) @map("is_antibiotic")
  dosage         String  @default("")
  frequency      String  @default("")
  duration       String  @default("")
  note           String  @default("")

  prescription MedPrescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@map("med_prescription_item")
}

model TravelDestination {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique @db.VarChar(255)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  trips       TravelTrip[]
  suggestions TravelSuggestion[]

  @@map("travel_destination")
}

model TravelSuggestion {
  id            BigInt   @id @default(autoincrement())
  destinationId BigInt   @map("destination_id")
  category      String   @db.VarChar(80)
  name          String   @db.VarChar(255)
  address       String   @default("")
  phone         String   @default("") @db.VarChar(80)
  openingHours  String   @default("") @map("opening_hours")
  description   String   @default("")
  mapUrl        String   @default("") @map("map_url")
  sourceUrl     String   @default("") @map("source_url")
  active        Boolean  @default(true)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  destination TravelDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([destinationId, category, name])
  @@map("travel_suggestion")
}

model TravelPerson {
  id           BigInt   @id @default(autoincrement())
  name         String   @db.VarChar(255)
  email        String   @default("") @db.VarChar(255)
  playerId     BigInt?  @map("player_id")
  ownerAdminId BigInt?  @map("owner_admin_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  player  Player?            @relation(fields: [playerId], references: [id], onDelete: SetNull)
  members TravelTripMember[]

  @@map("travel_person")
}

model TravelTrip {
  id                BigInt    @id @default(autoincrement())
  name              String    @db.VarChar(255)
  description       String    @default("")
  ownerAdminId      BigInt?   @map("owner_admin_id")
  destinationId     BigInt?   @map("destination_id")
  treasurerMemberId BigInt?   @unique @map("treasurer_member_id")
  active            Boolean   @default(true)
  aiPlan            String?   @map("ai_plan")
  aiPlanAt          DateTime? @map("ai_plan_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  ownerAdmin      AppUser?               @relation("TravelTripOwner", fields: [ownerAdminId], references: [id], onDelete: SetNull)
  destination     TravelDestination?     @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  treasurerMember TravelTripMember?      @relation("TravelTripTreasurer", fields: [treasurerMemberId], references: [id], onDelete: SetNull)
  members         TravelTripMember[]     @relation("TravelTripMembers")
  collections     TravelTripCollection[]
  expenses        TravelTripExpense[]
  permissions     TravelTripPermission[]

  @@map("travel_trip")
}

model TravelTripPermission {
  id        BigInt   @id @default(autoincrement())
  tripId    BigInt   @map("trip_id")
  adminId   BigInt   @map("admin_id")
  createdAt DateTime @default(now()) @map("created_at")

  trip  TravelTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  admin AppUser    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([tripId, adminId])
  @@map("travel_trip_permission")
}

model TravelTripMember {
  id        BigInt   @id @default(autoincrement())
  tripId    BigInt   @map("trip_id")
  personId  BigInt?  @map("person_id")
  playerId  BigInt?  @map("player_id")
  name      String   @db.VarChar(255)
  email     String   @default("") @db.VarChar(255)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  trip            TravelTrip               @relation("TravelTripMembers", fields: [tripId], references: [id], onDelete: Cascade)
  person          TravelPerson?            @relation(fields: [personId], references: [id], onDelete: SetNull)
  player          Player?                  @relation(fields: [playerId], references: [id], onDelete: SetNull)
  collections     TravelTripCollection[]
  paidExpenses    TravelTripExpense[]      @relation("TravelExpensePayer")
  privateExpenses TravelTripExpense[]      @relation("TravelExpensePrivateMember")
  splits          TravelTripExpenseSplit[]
  treasurerFor    TravelTrip?              @relation("TravelTripTreasurer")

  @@map("travel_trip_member")
}

model TravelTripCollection {
  id        BigInt   @id @default(autoincrement())
  tripId    BigInt   @map("trip_id")
  memberId  BigInt   @map("member_id")
  amount    Decimal  @default(0) @db.Decimal(14, 2)
  note      String   @default("")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  trip   TravelTrip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  member TravelTripMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tripId, memberId])
  @@map("travel_trip_collection")
}

model TravelTripExpense {
  id              BigInt   @id @default(autoincrement())
  tripId          BigInt   @map("trip_id")
  spentDate       DateTime @default(now()) @map("spent_date") @db.Date
  title           String   @db.VarChar(255)
  amount          Decimal  @default(0) @db.Decimal(14, 2)
  note            String   @default("")
  splitMode       String   @default("SHARED") @map("split_mode") @db.VarChar(20)
  privateMemberId BigInt?  @map("private_member_id")
  paidByMemberId  BigInt?  @map("paid_by_member_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  trip          TravelTrip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  privateMember TravelTripMember?        @relation("TravelExpensePrivateMember", fields: [privateMemberId], references: [id], onDelete: SetNull)
  paidByMember  TravelTripMember?        @relation("TravelExpensePayer", fields: [paidByMemberId], references: [id], onDelete: SetNull)
  splits        TravelTripExpenseSplit[]

  @@map("travel_trip_expense")
}

model TravelTripExpenseSplit {
  id        BigInt  @id @default(autoincrement())
  expenseId BigInt  @map("expense_id")
  memberId  BigInt  @map("member_id")
  amount    Decimal @default(0) @db.Decimal(14, 2)

  expense TravelTripExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member  TravelTripMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([expenseId, memberId])
  @@map("travel_trip_expense_split")
}

// ─── Module Quản Lý Chi Tiêu (household) ───
// Quét email VPBank (tiền RA) từ 1 hòm Gmail chung của 2 vợ chồng, đối chiếu với
// ngân sách tuần (cộng dồn phần dư) và mức tiết kiệm tháng. Xem docs/quan-ly-chi-tieu.md.

/// Cấu hình dùng chung, chỉ có đúng 1 dòng (id = 1).
model HouseholdConfig {
  id             Int      @id @default(1)
  weeklyBudget   BigInt   @default(0) @map("weekly_budget")
  monthlySavings BigInt   @default(0) @map("monthly_savings")
  weekStartDow   Int      @default(1) @map("week_start_dow") // 1 = Thứ Hai
  anchorDate     DateTime @default(now()) @map("anchor_date") @db.Date
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("household_config")
}

/// Số tài khoản "của nhà" để gắn nhãn giao dịch (Chồng/Vợ). KHÔNG dùng để loại
/// trừ: chuyển nội bộ giữa 2 vợ chồng qua VPBank vẫn tính là chi tiêu.
model HouseholdAccount {
  id            BigInt   @id @default(autoincrement())
  accountNumber String   @unique @map("account_number") @db.VarChar(40)
  ownerLabel    String   @map("owner_label") @db.VarChar(80)
  kind          String   @default("spending") @db.VarChar(20) // spending | savings
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("household_account")
}

/// Mỗi email giao dịch VPBank = 1 dòng. txnCode để chống trùng (upsert).
model HouseholdTxn {
  id            BigInt   @id @default(autoincrement())
  txnCode       String   @unique @map("txn_code") @db.VarChar(160)
  occurredAt    DateTime @map("occurred_at")
  performedBy   String   @default("") @map("performed_by") @db.VarChar(255)
  debitAccount  String   @default("") @map("debit_account") @db.VarChar(40)
  creditAccount String   @default("") @map("credit_account") @db.VarChar(40)
  beneficiary   String   @default("") @db.VarChar(255)
  amount        BigInt   @default(0)
  fee           BigInt   @default(0)
  description   String   @default("")
  category      String   @default("spending") @db.VarChar(20) // spending | excluded
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([occurredAt])
  @@map("household_txn")
}

/// Sổ tiết kiệm: mỗi lần "lẹm" (bù sang chi tiêu, giảm tiết kiệm) hoặc điều chỉnh tay.
model HouseholdSavingsEntry {
  id         BigInt   @id @default(autoincrement())
  kind       String   @default("topup") @db.VarChar(20) // topup = bù sang chi tiêu | adjust = điều chỉnh tay
  amount     BigInt   @default(0)
  note       String   @default("")
  needsNote  Boolean  @default(false) @map("needs_note")
  occurredAt DateTime @default(now()) @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("household_savings_entry")
}
