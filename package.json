{
  "name": "vodich-tool",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "prisma generate",
    "build": "nest build",
    "test": "npm run build && node --test test/*.test.js",
    "test:e2e": "npm run build && node scripts/run-e2e.js",
    "seed:e2e": "node scripts/seed-e2e.js",
    "check:render": "node scripts/check-render-ready.js",
    "backup": "node scripts/backup-db.js",
    "backup:push": "node scripts/backup-push.js",
    "restore": "node scripts/restore-db.js",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "render:build": "npm ci && npx prisma migrate deploy && npx prisma generate && npm run build && npm prune --omit=dev && npm cache clean --force",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/websockets": "^10.4.15",
    "@prisma/client": "^6.1.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "connect-redis": "^9.0.0",
    "ejs": "^3.1.10",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "redis": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "20.x"
  }
}
